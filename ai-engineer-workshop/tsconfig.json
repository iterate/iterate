{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "strict": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "ai-engineer-workshop": ["./sdk.ts"],
      "ai-engineer-workshop/contract": ["./contract.ts"]
    },
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "..",
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["dist"]
}
