{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "lib": ["ES2024", "DOM"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "ai-engineer-workshop": ["../lib/sdk.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["web"]
}
