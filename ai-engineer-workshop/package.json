{
  "name": "ai-engineer-workshop",
  "version": "0.0.1",
  "description": "CLI and lightweight SDK wrappers for the Iterate events workshop",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iterate/iterate.git",
    "directory": "ai-engineer-workshop"
  },
  "homepage": "https://github.com/iterate/iterate/tree/main/ai-engineer-workshop",
  "bugs": {
    "url": "https://github.com/iterate/iterate/issues"
  },
  "keywords": [
    "iterate",
    "events",
    "workshop"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "ai-engineer-workshop": "./dist/cli.js",
    "workshop": "./dist/cli.js"
  },
  "exports": {
    ".": "./sdk.ts",
    "./contract": "./contract.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/sdk.js",
        "types": "./dist/sdk.d.ts"
      },
      "./contract": {
        "import": "./dist/contract.js",
        "types": "./dist/contract.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm test:e2e",
    "test:e2e": "vitest run --dir e2e/vitest --maxWorkers 1",
    "test:watch": "vitest --dir e2e/vitest --maxWorkers 1",
    "workshop": "node --import tsx ./cli.ts",
    "w": "pnpm workshop"
  },
  "dependencies": {
    "@orpc/client": "1.13.13",
    "@orpc/contract": "1.13.13",
    "@orpc/openapi-client": "1.13.13",
    "@slack/web-api": "^7.15.0",
    "openai": "^6.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "4.0.15"
  }
}
