{
  "name": "iterate-root",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev-all": "sh -c 'export VITE_AUTH_APP_ORIGIN=http://localhost:7101; export VITE_PUBLIC_URL=http://localhost:7101; export ITERATE_OAUTH_ISSUER=http://localhost:7101/api/auth; (cd apps/auth && doppler run --preserve-env=VITE_AUTH_APP_ORIGIN,VITE_PUBLIC_URL -- pnpm dev:local) & (cd apps/os && doppler run --preserve-env=ITERATE_OAUTH_ISSUER -- pnpm dev); wait'",
    "dev": "pnpm os dev",
    "build": "pnpm -r --parallel --filter '!iterate' build",
    "typecheck": "pnpm -r --parallel --filter '!iterate' typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "os": "cd apps/os && pnpm",
    "skills:sync": "npx skills add . --skill '*' -a claude-code -a opencode -g -y",
    "skills:list": "npx skills list -g -a claude-code -a opencode",
    "iterate": "node ./packages/iterate/bin/iterate.js",
    "preview": "node ./packages/iterate/bin/iterate.js --local-router ./scripts/preview/router.ts local-router preview",
    "preview:ci": "./scripts/preview/run-ci-locally.sh",
    "lint": "oxlint . --threads 1 --deny-warnings",
    "lint:check": "pnpm lint",
    "lint:fix": "oxlint . --fix",
    "knip": "knip --workspace apps/os --workspace apps/semaphore --workspace apps/streams-example-app --workspace packages/shared",
    "prepare": "is-ci || husky",
    "spec": "playwright test --config playwright.config.ts",
    "vitest": "pnpm --dir apps/os test",
    "test": "pnpm -r --parallel --filter '!iterate' test",
    "test:onboarding": "pnpm -r --parallel --filter '!iterate' test:onboarding",
    "test:onboarding:production": "pnpm -r --parallel --filter '!iterate' test:onboarding:production",
    "db:migrate": "pnpm --dir apps/os sqlfu:migrate",
    "db:generate": "pnpm --dir apps/os sqlfu:generate",
    "db:studio": "pnpm --dir apps/os sqlfu:ui",
    "clean": "rm -rf ./**/node_modules",
    "workflows": "cd .github/ts-workflows && pnpm generate",
    "super-reset": "pnpm i && pnpm -r --parallel --filter '!iterate' super-reset",
    "auth:mint": "tsx scripts/auth/mint-session.ts"
  },
  "devDependencies": {
    "@iterate-com/auth-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@playwright/test": "1.60.0",
    "@tanstack/eslint-plugin-router": "^1.139.0",
    "@types/node": "^24.10.1",
    "@typescript/native-preview": "^7.0.0-dev.20260203.1",
    "dedent": "^1.7.0",
    "eslint-plugin-codegen": "0.34.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "esquery": "1.6.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "knip": "^6.0.5",
    "lint-staged": "^16.2.7",
    "middlewright": "^0.1.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "playwright": "1.60.0",
    "skills": "^1.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "@orpc/client": "1.13.14",
    "@orpc/server": "1.13.14",
    "zod": "^4.3.6"
  }
}
