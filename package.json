{
  "name": "iterate-root",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "pnpm os dev",
    "build": "pnpm -r --parallel build",
    "typecheck": "pnpm -r --parallel --filter '!@iterate-com/daemon-v2' --filter '!@iterate-com/daemon-v2-contract' --filter '!@iterate-com/fake-os' --filter '!@iterate-com/fake-os-contract' --filter '!@iterate-com/jonasland' --filter '!@iterate-com/jonasland-e2e' --filter '!@iterate-com/jonasland-sandbox' typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "os": "cd apps/os && pnpm",
    "events": "cd apps/events && pnpm",
    "daemon": "cd apps/daemon && pnpm",
    "sandbox": "cd sandbox && pnpm",
    "jonasland": "cd jonasland && pnpm",
    "cli": "cd apps/cli && pnpm tsx main.ts",
    "skills:sync": "npx skills add . --skill '*' -a claude-code -a opencode -g -y",
    "skills:list": "npx skills list -g -a claude-code -a opencode",
    "preview": "node ./packages/iterate/bin/iterate.js --local-router ./scripts/preview/router.ts local-router preview",
    "spec": "playwright test",
    "video": "VIDEO_MODE=1 playwright test",
    "lint": "oxlint . --threads 1 --deny-warnings",
    "lint:check": "pnpm lint",
    "lint:fix": "oxlint . --fix",
    "knip": "knip --workspace apps/example --workspace apps/example-contract --workspace apps/events --workspace apps/events-contract --workspace apps/ingress-proxy --workspace apps/ingress-proxy-contract --workspace apps/semaphore --workspace apps/semaphore-contract --workspace apps/daemon-v2 --workspace apps/daemon-v2-contract --workspace packages/shared",
    "prepare": "is-ci || husky",
    "vitest": "pnpm os test",
    "test": "pnpm -r --parallel --filter '!@iterate-com/daemon-v2' --filter '!@iterate-com/fake-os' --filter '!@iterate-com/jonasland-e2e' test",
    "test:onboarding": "pnpm -r --parallel test:onboarding",
    "test:onboarding:production": "pnpm -r --parallel test:onboarding:production",
    "seed:tunnel-pool": "pnpm --dir apps/semaphore run seed:tunnel-pool",
    "docker:up": "tsx ./scripts/docker-compose.ts up -d",
    "docker:down": "tsx ./scripts/docker-compose.ts down --remove-orphans && tsx ./scripts/docker-remove-project-containers.ts",
    "docker:clean": "tsx ./scripts/docker-compose.ts down -v --remove-orphans && tsx ./scripts/docker-remove-project-containers.ts",
    "db:migrate": "pnpm os db:migrate",
    "db:generate": "pnpm os db:generate",
    "db:studio": "pnpm os db:studio",
    "db:studio:staging": "PSCALE_DATABASE_URL=$(doppler secrets --config stg get --plain DRIZZLE_ADMIN_POSTGRES_CONNECTION_STRING) pnpm db:studio",
    "db:studio:production": "PSCALE_DATABASE_URL=$(doppler secrets get --plain DANGEROUS_PRODUCTION_POSTGRES_URL) pnpm db:studio",
    "db:shell:production": "psql \"$(doppler secrets get --plain DANGEROUS_PRODUCTION_POSTGRES_URL)\"",
    "db:query": "tsx ./scripts/docker-compose.ts exec postgres psql -U postgres -d os",
    "db:query:file": "tsx ./scripts/docker-compose.ts exec -T postgres psql -U postgres -d os -f",
    "db:exec": "tsx ./scripts/docker-compose.ts exec -T postgres psql -U postgres -d os -c",
    "clean": "rm -rf ./**/node_modules",
    "workflows": "cd .github/ts-workflows && pnpm generate",
    "publish-cli": "node packages/iterate/pubme.js publish",
    "super-reset": "pnpm i && pnpm docker:clean && pnpm docker:up && sleep 3 && pnpm -r --parallel super-reset"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tanstack/eslint-plugin-router": "^1.139.0",
    "@types/node": "^24.10.1",
    "@typescript/native-preview": "^7.0.0-dev.20260203.1",
    "dedent": "^1.7.0",
    "emittery": "1.2.0",
    "eslint-plugin-codegen": "0.34.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "github:mmkal/eslint-plugin-unicorn#4b6340834f94ebb53a1aee5b91dd5c0e103249b3",
    "esquery": "1.6.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "knip": "^6.0.5",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "playwright": "^1.57.0",
    "playwright-core": "1.57.0",
    "skills": "^1.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "overrides": {
      "axios": "1.13.6",
      "@orpc/client": "1.13.13",
      "@orpc/contract": "1.13.13",
      "@orpc/openapi": "1.13.13",
      "@orpc/openapi-client": "1.13.13",
      "@orpc/otel": "1.13.13",
      "@orpc/react-query": "1.13.13",
      "@orpc/server": "1.13.13",
      "@orpc/shared": "1.13.13",
      "@orpc/tanstack-query": "1.13.13",
      "@orpc/zod": "1.13.13",
      "baseline-browser-mapping": "^2.9.14",
      "@babel/parser": "^7.28.0",
      "workerd": "1.20260205.0",
      "miniflare": "4.20260205.0"
    }
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "@orpc/client": "1.13.13",
    "@orpc/server": "1.13.13",
    "zod": "^4.3.6"
  }
}
