  "scripts": {
    "typecheck": "tsc --noEmit && pnpm typecheck:callable",
    "typecheck:callable": "tsc -p src/callable/tsconfig.vitest.json --noEmit",
    "test": "pnpm test:codemode && pnpm test:callable && pnpm test:durable-object-utils",
    "test:codemode": "vitest run --environment node src/codemode/*.test.ts",
    "test:callable": "vitest run --config src/callable/vitest.config.ts",
    "test:durable-object-utils": "pnpm test:durable-object-utils:type && pnpm test:durable-object-utils:unit",
    "test:durable-object-utils:type": "vitest run --config ./src/durable-object-utils/vitest.type.config.ts --typecheck.only",
    "test:durable-object-utils:unit": "vitest run --config ./src/durable-object-utils/vitest.unit.config.ts",
    "test:durable-object-utils:e2e": "node -e \"if (!process.env.DURABLE_OBJECT_UTILS_E2E_BASE_URL) { console.error('DURABLE_OBJECT_UTILS_E2E_BASE_URL is required'); process.exit(1); }\" && vitest run --config ./src/durable-object-utils/e2e/vitest.config.ts",
    "test:durable-object-utils:e2e:deploy": "tsx ./src/durable-object-utils/e2e/run-test-deployment.ts",
    "deploy:durable-object-utils:e2e": "sh -c 'stage=\"${ALCHEMY_STAGE:-do-utils-e2e}\"; ALCHEMY_STAGE=\"$stage\" pnpm exec alchemy deploy ./src/durable-object-utils/e2e/alchemy.run.ts --stage \"$stage\"'"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
