{
  "name": "@iterate-com/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./jonasland": "./src/jonasland/index.ts",
    "./jonasland/ingress-url": "./src/jonasland/ingress-url.ts",
    "./jonasland/deployment": "./src/jonasland/deployment/index.ts",
    "./force-public-url-vite-plugin": "./src/dev/force-public-url-vite-plugin.ts",
    "./project-ingress": "./src/project-ingress.ts",
    "./github-agent-path": "./src/github-agent-path.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment node src/jonasland/ingress-url.test.ts",
    "fly-api:spec:refresh": "curl -fsSL https://docs.machines.dev/spec/openapi3.json -o ./src/jonasland/deployment/fly-api/openapi/openapi3.json",
    "fly-api:spec:prepare": "node ./src/jonasland/deployment/fly-api/openapi/prepare-openapi.mjs",
    "fly-api:generate": "openapi-ts -f ./src/jonasland/deployment/fly-api/openapi-ts.config.cjs",
    "fly-api:regen": "pnpm run fly-api:spec:refresh && pnpm run fly-api:spec:prepare && pnpm run fly-api:generate",
    "fly-api:check": "pnpm run fly-api:generate && git diff --exit-code -- ./src/jonasland/deployment/fly-api/generated"
  },
  "dependencies": {
    "@accelerated-software-development/caddy-api-client": "^0.4.3",
    "@docker/node-sdk": "^0.0.17",
    "@iterate-com/events-contract": "workspace:*",
    "@iterate-com/registry-service": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.206.0",
    "@opentelemetry/instrumentation-http": "^0.206.0",
    "@opentelemetry/instrumentation-undici": "^0.16.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@orpc/client": "^1.13.5",
    "@orpc/contract": "^1.13.5",
    "@orpc/openapi-client": "^1.13.5",
    "@orpc/otel": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@orpc/zod": "^1.13.5",
    "delay": "^7.0.0",
    "evlog": "^1.8.0",
    "p-retry": "^7.1.1",
    "p-wait-for": "^6.0.0",
    "pidnap": "workspace:*",
    "ws": "^8.18.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.93.1",
    "@types/node": "^25.0.10",
    "typescript": "^5.9.3",
    "vite": "7.2.4",
    "vitest": "^4.0.18"
  }
}
