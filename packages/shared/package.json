    "@posthog/rollup-plugin": "^1.2.14",
    "@slack/types": "^2.20.0",
    "acorn": "^8.16.0",
    "alchemy": "^0.83.3",
    "croner": "^10.0.1",
    "dequal": "^2.0.3",
    "evlog": "^1.8.0",
    "get-port": "^7.1.0",
