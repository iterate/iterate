{
  "name": "@iterate-com/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "iterate-app-cli": "./bin/iterate-app-cli.js"
  },
  "exports": {
    "./config": "./src/config.ts",
    "./evlog": "./src/evlog/with-evlog.ts",
    "./evlog/types": "./src/evlog/types.ts",
    "./evlog/stdout": "./src/evlog/stdout.ts",
    "./evlog/runtime": "./src/evlog/runtime.ts",
    "./evlog/orpc-plugin": "./src/evlog/orpc-plugin.ts",
    "./alchemy/init": "./src/alchemy/init.ts",
    "./alchemy/artifacts": "./src/alchemy/artifacts.ts",
    "./alchemy/iterate-app": "./src/alchemy/iterate-app.ts",
    "./alchemy/local-dev-server": "./src/alchemy/local-dev-server.ts",
    "./alchemy/start-cloudflared": "./src/alchemy/start-cloudflared.ts",
    "./apps/cli": "./src/apps/cli.ts",
    "./apps/internal-router-contract": "./src/apps/internal-router-contract.ts",
    "./test-helpers": "./src/test-helpers/index.ts",
    "./test-support/vitest-e2e": "./src/test-support/vitest-e2e/index.ts",
    "./durable-object-utils/mixins/with-durable-object-core": "./src/durable-object-utils/mixins/with-durable-object-core.ts",
    "./durable-object-utils/mixins/with-lifecycle-hooks": "./src/durable-object-utils/mixins/with-lifecycle-hooks.ts",
    "./durable-object-utils/mixins/with-kv-inspector": "./src/durable-object-utils/mixins/with-kv-inspector.ts",
    "./durable-object-utils/mixins/with-outerbase": "./src/durable-object-utils/mixins/with-outerbase.ts",
    "./durable-object-utils/iterate-durable-object": "./src/durable-object-utils/iterate-durable-object.ts",
    "./streams/circuit-breaker-types": "./src/streams/circuit-breaker-types.ts",
    "./streams/compiled-jsonata": "./src/streams/compiled-jsonata.ts",
    "./streams/core-event-types": "./src/streams/core-event-types.ts",
    "./streams/event-base-types": "./src/streams/event-base-types.ts",
    "./streams/external-subscriber-types": "./src/streams/external-subscriber-types.ts",
    "./streams/html-renderer-types": "./src/streams/html-renderer-types.ts",
    "./streams/jsonata-expression": "./src/streams/jsonata-expression.ts",
    "./streams/stream-event": "./src/streams/stream-event.ts",
    "./streams/stream-processors": "./src/streams/stream-processors.ts",
    "./streams/types": "./src/streams/types.ts",
    "./request-logging": "./src/request-logging.ts",
    "./slugify": "./src/slugify.ts",
    "./typeid": "./src/typeid.ts",
    "./posthog": {
      "types": "./src/posthog/posthog.ts",
      "import": "./src/posthog/posthog.ts",
      "default": "./src/posthog/posthog.ts"
    },
    "./callable/runtime.ts": "./src/callable/runtime.ts",
    "./callable/descriptor-types.ts": "./src/callable/descriptor-types.ts",
    "./callable/types.ts": "./src/callable/types.ts",
    "./type-tree/utils": "./src/type-tree/utils.ts",
    "./type-tree/type-tree": "./src/type-tree/type-tree.ts",
    "./type-tree/json-schema-types": "./src/type-tree/json-schema-types.ts",
    "./project-ingress": "./src/project-ingress.ts",
    "./auth-claims": "./src/auth-claims.ts",
    "./oauth-resource": "./src/oauth-resource.ts",
    "./bearer": "./src/bearer.ts",
    "./slug": "./src/slug.ts",
    "./default-avatar": "./src/default-avatar.ts",
    "./signup-allowlist": "./src/signup-allowlist.ts",
    "./slug-maker": "./src/slug-maker.ts",
    "./nitro-ws-response": "./src/nitro-ws-response.ts",
    "./node/run-command": "./src/node/run-command.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit && pnpm typecheck:callable",
    "typecheck:callable": "tsc -p src/callable/tsconfig.vitest.json --noEmit",
    "test": "pnpm test:type-tree && pnpm test:callable && pnpm test:durable-object-utils",
    "test:type-tree": "vitest run --environment node src/type-tree/*.test.ts",
    "test:callable": "vitest run --config src/callable/vitest.config.ts",
    "test:durable-object-utils": "pnpm test:durable-object-utils:type && pnpm test:durable-object-utils:unit",
    "test:durable-object-utils:type": "vitest run --config ./src/durable-object-utils/vitest.type.config.ts --typecheck.only",
    "test:durable-object-utils:unit": "vitest run --config ./src/durable-object-utils/vitest.unit.config.ts",
    "test:durable-object-utils:e2e": "node -e \"if (!process.env.DURABLE_OBJECT_UTILS_E2E_BASE_URL) { console.error('DURABLE_OBJECT_UTILS_E2E_BASE_URL is required'); process.exit(1); }\" && vitest run --config ./src/durable-object-utils/e2e/vitest.config.ts",
    "test:durable-object-utils:e2e:deploy": "tsx ./src/durable-object-utils/e2e/run-test-deployment.ts",
    "deploy:durable-object-utils:e2e": "sh -c 'stage=\"${ALCHEMY_STAGE:-do-utils-e2e}\"; ALCHEMY_STAGE=\"$stage\" pnpm exec alchemy deploy ./src/durable-object-utils/e2e/alchemy.run.ts --stage \"$stage\"'"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@orpc/client": "1.13.14",
    "@orpc/contract": "1.13.14",
    "@orpc/server": "1.13.14",
    "@orpc/shared": "1.13.14",
    "@effect/platform-bun": "beta",
    "@effect/platform-node": "beta",
    "alchemy": "next",
    "dequal": "^2.0.3",
    "effect": "beta",
    "evlog": "^1.8.0",
    "get-port": "^7.1.0",
    "jsonata": "^2.1.0",
    "minimatch": "^10.1.1",
    "nitro": "3.0.260311-beta",
    "react": "^19.2.4",
    "trpc-cli": "0.14.0",
    "tsx": "^4.21.0",
    "type-fest": "^5.5.0",
    "typeid-js": "^1.2.0",
    "vite": "7.3.1",
    "yaml": "^2.8.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:cloudflare",
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wrangler": "catalog:cloudflare"
  }
}
