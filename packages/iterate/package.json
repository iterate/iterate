{
  "name": "iterate",
  "version": "0.2.6",
  "description": "CLI for iterate",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iterate/iterate",
    "directory": "packages/iterate"
  },
  "homepage": "https://github.com/iterate/iterate#readme",
  "bugs": {
    "url": "https://github.com/iterate/iterate/issues"
  },
  "keywords": [
    "iterate",
    "cli",
    "orpc"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "iterate": "./bin/iterate.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      },
      "./worker": {
        "import": "./dist/worker.mjs",
        "types": "./dist/worker.d.mts"
      }
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@opentui/core": "0.1.102",
    "@opentui/react": "0.1.102",
    "@orpc/client": "1.13.14",
    "@orpc/server": "1.13.14",
    "better-auth": "1.4.3",
    "react": "^19.2.0",
    "trpc-cli": "0.15.1",
    "yaml": "^2.8.3",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@iterate-com/auth-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsdown": "0.22.2",
    "vitest": "4.0.15"
  }
}
