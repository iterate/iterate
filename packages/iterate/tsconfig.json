{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "lib": ["esnext", "dom"],
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "types": ["node"],
    "paths": {
      "@iterate-com/auth-contract": ["../../apps/auth-contract/src/index.ts"],
      "@iterate-com/shared/*": ["../shared/src/*"],
      "@iterate-com/ui/*": ["../ui/src/*"]
    },
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "rewriteRelativeImportExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "../..",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
