{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "autoupdate": false,
  "lsp": false,
  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    }
  },
  "permission": "allow",
  "mcp": {
    "metamcp": {
      "type": "remote",
      "url": "http://127.0.0.1:19070/mcp",
      "enabled": true
    }
  }
}
