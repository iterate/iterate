{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "embeddedLanguageFormatting": "auto",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/",
    ".pnpm-store/",
    "dist/",
    "build/",
    ".next/",
    ".wrangler/",
    "routeTree.gen.ts",
    "worker-configuration.d.ts",
    "logs.json",
    ".github/workflows/",
    ".git/",
    "**/db/migrations/**",
    "**/.corepack/**",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "**/.repomix-*",
    "**/.alchemy",
    "**/.iterate/",
    "**/components/ui/",
    "**/components/ai-elements/"
  ]
}
