{
    admin 0.0.0.0:2019
    local_certs
}

:80 {
    @health path /healthz
    respond @health "ok" 200

    @openobserve host openobserve.iterate.localhost
    handle @openobserve {
        reverse_proxy {
            header_up Authorization "Basic cm9vdEBleGFtcGxlLmNvbTpDb21wbGV4cGFzcyMxMjM="
            dynamic srv {
                name openobserve.service.consul
                resolvers 127.0.0.1:53
                refresh 1s
            }
        }
    }

    @signoz host signoz.iterate.localhost
    handle @signoz {
        @signoz_autologin path /
        handle @signoz_autologin {
            root * /etc/jonasland2/caddy/static
            rewrite * /signoz-autologin.html
            file_server
        }

        reverse_proxy {
            dynamic srv {
                name signoz.service.consul
                resolvers 127.0.0.1:53
                refresh 1s
            }
        }
    }

    @home host home.iterate.localhost
    handle @home {
        reverse_proxy {
            dynamic srv {
                name home-service.service.consul
                resolvers 127.0.0.1:53
                refresh 1s
            }
        }
    }

    @events host events.iterate.localhost
    handle @events {
        tracing {
            span "caddy-events-http"
        }

        reverse_proxy {
            dynamic srv {
                name events-service.service.consul
                resolvers 127.0.0.1:53
                refresh 1s
            }
        }
    }

    @orders host orders.iterate.localhost
    handle @orders {
        tracing {
            span "caddy-orders-http"
        }

        reverse_proxy {
            dynamic srv {
                name orders-service.service.consul
                resolvers 127.0.0.1:53
                refresh 1s
            }
        }
    }

    @outerbase host outerbase.iterate.localhost
    handle @outerbase {
        reverse_proxy {
            dynamic srv {
                name outerbase-studio.service.consul
                resolvers 127.0.0.1:53
                refresh 1s
            }
        }
    }

    @nomad host nomad.iterate.localhost
    handle @nomad {
        reverse_proxy 127.0.0.1:4646
    }

    @consul host consul.iterate.localhost
    handle @consul {
        reverse_proxy 127.0.0.1:8500
    }

    reverse_proxy 127.0.0.1:19000 {
        header_up X-Original-Host {http.request.header.Host}
        header_up X-Original-SNI {http.request.tls.server_name}
        header_up X-Original-Proto {http.request.scheme}
    }
}

:443 {
    tls internal {
        on_demand
    }

    @health path /healthz
