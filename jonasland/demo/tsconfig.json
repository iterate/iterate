{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": ["node", "vite/client"],
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@iterate-com/ui": ["../../packages/ui/src/index.ts"],
      "@iterate-com/ui/*": ["../../packages/ui/src/*"]
    },
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "server.ts", "scripts/**/*.ts", "vite.config.ts"]
}
