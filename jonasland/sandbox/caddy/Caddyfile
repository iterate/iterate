:80, :8080 {
    @health path /healthz
    respond @health "ok" 200

    @frp_control host frp-control.iterate.localhost
    handle @frp_control {
        reverse_proxy 127.0.0.1:27000
    }

    @frp_data host *.frp-egress.iterate.localhost
    handle @frp_data {
        reverse_proxy 127.0.0.1:27080
    }

    @frp_control_ws {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @frp_control_ws {
        reverse_proxy 127.0.0.1:27000
    }

    @local host 127.0.0.1 localhost
    handle @local {
        respond "caddy ok" 200
    }

    reverse_proxy 127.0.0.1:19000 {
        header_up X-Iterate-Original-Host {http.request.header.Host}
        header_up X-Iterate-Original-SNI {http.request.tls.server_name}
        header_up X-Iterate-Original-Proto {http.request.scheme}
    }
}

:443, :8443 {
    tls internal {
        on_demand
    }

    @events host events.iterate.localhost
    handle @events {
        import iterate_cors_openapi
        tracing {
            span "caddy-events-https"
        }

        reverse_proxy 127.0.0.1:19010
    }

    @orders host orders.iterate.localhost
    handle @orders {
        import iterate_cors_openapi
        tracing {
            span "caddy-orders-https"
        }

        reverse_proxy 127.0.0.1:19020
    }

    @docs host docs.iterate.localhost
    handle @docs {
        import iterate_cors_openapi
        reverse_proxy 127.0.0.1:19050
    }

    @openobserve host openobserve.iterate.localhost
    handle @openobserve {
        reverse_proxy 127.0.0.1:5080 {
            header_up Authorization "Basic cm9vdEBleGFtcGxlLmNvbTpDb21wbGV4cGFzcyMxMjM="
        }
    }

    @clickstack host clickstack.iterate.localhost
    handle @clickstack {
        reverse_proxy 127.0.0.1:8080
    }

    @caddymanager host caddymanager.iterate.localhost
    handle @caddymanager {
        reverse_proxy 127.0.0.1:8501
    }

    @frp_control host frp-control.iterate.localhost
    handle @frp_control {
        reverse_proxy 127.0.0.1:27000 {
            stream_close_delay 5m
        }
    }

    @frp_data host *.frp-egress.iterate.localhost
    handle @frp_data {
        reverse_proxy 127.0.0.1:27080
    }

    @frp_control_ws {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @frp_control_ws {
        reverse_proxy 127.0.0.1:27000 {
            stream_close_delay 5m
        }
    }

    reverse_proxy 127.0.0.1:19000 {
        header_up X-Iterate-Original-Host {http.request.header.Host}
        header_up X-Iterate-Original-SNI {http.request.tls.server_name}
        header_up X-Iterate-Original-Proto {http.request.scheme}
    }
}
