{
    admin 0.0.0.0:2019

    pki {
        ca local {
            name "Egress MITM Proxy CA"
        }
    }

    storage file_system {
        root /var/lib/caddy
    }

    consul {
        address "http://127.0.0.1:8500"
        global_config_key "caddy/global"
        consul_services_tag "caddy"
    }
}

:2018 {
    respond "bootstrap" 200
}
