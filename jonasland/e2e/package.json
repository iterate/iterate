{
  "name": "@iterate-com/jonasland-e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "vitest": "doppler run --preserve-env=JONASLAND_SANDBOX_IMAGE -- vitest run --tags-filter='!fly'",
    "vitest:all": "doppler run --preserve-env=JONASLAND_SANDBOX_IMAGE -- vitest run",
    "vitest:docker": "doppler run --preserve-env=JONASLAND_SANDBOX_IMAGE -- vitest run --tags-filter=docker",
    "vitest:fly": "doppler run --preserve-env=JONASLAND_SANDBOX_IMAGE -- vitest run --tags-filter=fly",
    "playwright": "doppler run --preserve-env=JONASLAND_SANDBOX_IMAGE -- playwright test",
    "tags": "doppler run --preserve-env=JONASLAND_SANDBOX_IMAGE -- vitest --list-tags",
    "test": "pnpm vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@iterate-com/example-old": "workspace:*",
    "@iterate-com/example-contract": "workspace:*",
    "@iterate-com/semaphore-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*"
  },
  "devDependencies": {
    "@iterate-com/mock-http-proxy": "workspace:*",
    "@types/node": "^25.0.10",
    "emittery": "1.2.0",
    "mockttp": "^4.2.1",
    "msw": "^2.12.10",
    "typescript": "^5.9.3",
    "vitest": "4.1.0-beta.6",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
