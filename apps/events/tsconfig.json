{
  "include": ["**/*.ts", "**/*.tsx", "alchemy.run.ts"],
  "compilerOptions": {
    "target": "ES2024",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "~/*": ["./src/*"],
      "@iterate-com/ui/*": ["../../packages/ui/src/*"],
      "@iterate-com/shared/posthog/vite-plugin": [
        "../../packages/shared/src/posthog/sourcemaps-vite-plugin.ts"
      ]
    },
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node", "@cloudflare/workers-types"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true
  }
}
