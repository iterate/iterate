{
  "name": "@iterate-com/events",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "~/*": "./src/*"
  },
  "scripts": {
    "alchemy:up": "tsx ./alchemy.run.ts",
    "alchemy:down": "tsx ./alchemy.run.ts --destroy",
    "dev": "doppler run --project events -- tsx ./alchemy.run.ts",
    "build": "doppler run -- pnpm exec vite build",
    "deploy": "doppler run --project events --config prd -- pnpm alchemy:up",
    "destroy": "doppler run --project events --config prd -- pnpm alchemy:down",
    "demo": "pnpm iterate --local-router ./scripts/demo/router.ts local-router",
    "demo:hello-world": "pnpm iterate --local-router ./scripts/demo/router.ts local-router hello-world",
    "typecheck": "tsc --noEmit",
    "test": "pnpm typecheck && vitest run src",
    "test:e2e": "node -e \"if (!process.env.EVENTS_BASE_URL) { console.error('EVENTS_BASE_URL is required for events e2e tests'); process.exit(1); }\" && vitest run --dir e2e/vitest",
    "test:quick": "pnpm test:e2e",
    "test:watch": "node -e \"if (!process.env.EVENTS_BASE_URL) { console.error('EVENTS_BASE_URL is required for events e2e tests'); process.exit(1); }\" && vitest --dir e2e/vitest"
  },
  "dependencies": {
    "@iterate-com/events-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@orpc/client": "1.13.13",
    "@orpc/contract": "1.13.13",
    "@orpc/openapi": "1.13.13",
    "@orpc/openapi-client": "1.13.13",
    "@orpc/server": "1.13.13",
    "@orpc/tanstack-query": "1.13.13",
    "@tanstack/ai": "^0.2.2",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-form-devtools": "^0.2.19",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "1.168.3",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "1.167.5",
    "crossws": "^0.4.4",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@iterate-com/mock-http-proxy": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.83.3",
    "drizzle-kit": "^0.31.1",
    "esbuild": "^0.27.4",
    "msw": "^2.4.9",
    "tinyexec": "^1.0.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "4.0.15",
    "wrangler": "^4.75.0"
  }
}
