{
  "name": "@iterate-com/ingress-proxy-worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "doppler run -- tsx ./alchemy.run.ts cli --dev",
    "deploy": "doppler run -- tsx ./alchemy.run.ts cli deploy",
    "destroy": "doppler run -- tsx ./alchemy.run.ts cli --destroy",
    "test": "vitest run",
    "test:e2e-live": "vitest run --config ./vitest.live.config.ts",
    "typecheck": "tsc --noEmit",
    "db:rebuild": "rm -f .local.db && sqlite3 .local.db '' && find sql/migrations -name '*.sql' -print | sort | while read -r file; do sqlite3 .local.db < \"$file\"; done && sqlite3 .local.db '.schema --indent' > sql/schema.sql",
    "db:types": "tsx ./scripts/generate-queries.ts --force",
    "db:types:stale": "tsx ./scripts/generate-queries.ts --if-stale",
    "db:watch": "tsx ./scripts/generate-queries.ts --watch"
  },
  "dependencies": {
    "@iterate-com/ingress-proxy-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@orpc/openapi": "1.13.13",
    "@orpc/server": "1.13.13",
    "@orpc/zod": "1.13.13",
    "alchemy": "^0.83.0",
    "hono": "^4.12.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260207.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typesql-cli": "github:iterate/typesql#5687eb2",
    "typescript": "^5.9.3",
    "vitest": "3.2.4",
    "wrangler": "^4.64.0"
  }
}
