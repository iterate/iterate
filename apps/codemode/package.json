{
  "name": "@iterate-com/codemode",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "~/*": "./src/*"
  },
  "scripts": {
    "alchemy:up": "tsx ./alchemy.run.ts",
    "alchemy:down": "tsx ./alchemy.run.ts --destroy",
    "cli": "doppler run --project codemode -- iterate-app-cli",
    "dev": "doppler run --project codemode -- tsx ./alchemy.run.ts",
    "build": "doppler run --project codemode -- pnpm exec vite build --config vite.cf.config.ts",
    "deploy": "doppler run --project codemode --config prd -- pnpm alchemy:up",
    "destroy": "doppler run --project codemode --config prd -- pnpm alchemy:down",
    "rpc": "pnpm cli rpc",
    "typecheck": "tsc --noEmit",
    "test": "pnpm typecheck",
    "test:e2e": "node -e \"if (!process.env.CODEMODE_BASE_URL) { console.error('CODEMODE_BASE_URL is required for codemode e2e tests'); process.exit(1); }\" && vitest run --config ./e2e/vitest.config.ts",
    "test:e2e:preview": "pnpm test:e2e",
    "test:e2e:doppler": "node -e \"if (!process.env.CODEMODE_BASE_URL) { console.error('CODEMODE_BASE_URL is required for codemode e2e tests'); process.exit(1); } if (!process.env.DOPPLER_PROJECT || !process.env.DOPPLER_CONFIG) { console.error('DOPPLER_PROJECT and DOPPLER_CONFIG are required for codemode e2e Doppler runs'); process.exit(1); }\" && doppler run --project \"$DOPPLER_PROJECT\" --config \"$DOPPLER_CONFIG\" -- pnpm exec vitest run --config ./e2e/vitest.config.ts"
  },
  "dependencies": {
    "@cloudflare/codemode": "catalog:cloudflare",
    "@cloudflare/worker-bundler": "catalog:cloudflare",
    "@iterate-com/codemode-contract": "workspace:*",
    "@iterate-com/events-contract": "workspace:*",
    "@iterate-com/example-contract": "workspace:*",
    "@iterate-com/ingress-proxy-contract": "workspace:*",
    "@iterate-com/semaphore-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@orpc/client": "1.13.14",
    "@orpc/contract": "1.13.14",
    "@orpc/openapi": "1.13.14",
    "@orpc/openapi-client": "1.13.14",
    "@orpc/server": "1.13.14",
    "@orpc/tanstack-query": "1.13.14",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-form-devtools": "^0.2.19",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "1.168.3",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "1.167.5",
    "drizzle-orm": "^0.45.1",
    "json5": "^2.2.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.18",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:cloudflare",
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.83.3",
    "drizzle-kit": "^0.31.1",
    "esbuild": "^0.27.4",
    "iterate": "workspace:*",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "4.0.15",
    "wrangler": "catalog:cloudflare"
  }
}
