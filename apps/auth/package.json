{
  "name": "@iterate-com/auth",
  "version": "0.0.0-dev",
  "type": "module",
  "private": true,
  "exports": {
    "./server": "./src/lib/server.ts",
    "./client": "./src/lib/client.ts"
  },
  "scripts": {
    "alchemy:up": "tsx ./alchemy.run.ts",
    "alchemy:down": "tsx ./alchemy.run.ts --destroy",
    "dev:local": "alchemy dev",
    "dev": "doppler run --project auth --config dev -- alchemy dev",
    "auth:generate": "auth --config ./src/server/cli-auth.ts generate --output /tmp/auth-schema.sql --yes && cat /tmp/auth-schema.sql > ./defi.sql",
    "auth:dev": "doppler run --project auth --config dev -- alchemy dev",
    "build": "vite build",
    "typecheck": "tsgo --noEmit",
    "db:check": "sqlfu check",
    "db:draft": "sqlfu draft",
    "db:generate": "sqlfu generate",
    "db:migrate": "sqlfu migrate",
    "db:rebuild": "rm -f ./src/server/db/.local.db && pnpm db:migrate",
    "deploy:prd": "doppler run --project auth --config prd -- pnpm alchemy:up"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.9",
    "@iterate-com/auth-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@orpc/server": "^1.13.7",
    "@orpc/tanstack-query": "^1.13.6",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-start": "^1.166.11",
    "alchemy": "^0.83.3",
    "auth": "^1.6.9",
    "better-auth": "^1.6.9",
    "hono": "^4.12.8",
    "jose": "^6.2.1",
    "oauth4webapi": "^3.8.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "sqlfu": "https://pkg.pr.new/sqlfu@9ff2913",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:cloudflare",
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260315.1",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.0",
    "wrangler": "catalog:cloudflare"
  }
}
