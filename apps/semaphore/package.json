{
  "name": "@iterate-com/semaphore",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "~/*": "./src/*"
  },
  "scripts": {
    "alchemy:up": "tsx ./alchemy.run.ts",
    "alchemy:down": "tsx ./alchemy.run.ts --destroy",
    "cli": "doppler run --project semaphore -- iterate-app-cli",
    "dev": "doppler run -- pnpm alchemy:up",
    "build": "doppler run -- pnpm exec vite build",
    "deploy": "doppler run --config prd -- pnpm alchemy:up",
    "rpc": "pnpm cli rpc",
    "seed:preview-pool": "pnpm cli seed-cloudflare-preview-environment-pool",
    "seed:tunnel-pool": "pnpm cli seed-cloudflare-tunnel-pool",
    "typecheck": "tsc --noEmit",
    "test": "pnpm typecheck",
    "test:e2e": "node -e \"if (!process.env.SEMAPHORE_BASE_URL) { console.error('SEMAPHORE_BASE_URL is required for semaphore e2e tests'); process.exit(1); }\" && vitest run --config ./e2e/vitest.config.ts",
    "test:e2e:preview": "node -e \"if (!process.env.SEMAPHORE_BASE_URL) { console.error('SEMAPHORE_BASE_URL is required for semaphore e2e tests'); process.exit(1); }\" && vitest run --config ./e2e/vitest.config.ts ./e2e/vitest/preview.e2e.test.ts",
    "test:all": "pnpm run test && pnpm run test:e2e",
    "test:quick": "pnpm test:e2e",
    "test:watch": "node -e \"if (!process.env.SEMAPHORE_BASE_URL) { console.error('SEMAPHORE_BASE_URL is required for semaphore e2e tests'); process.exit(1); }\" && vitest --config ./e2e/vitest.config.ts",
    "destroy": "doppler run --config prd -- pnpm alchemy:down",
    "db:rebuild": "rm -f .local.db && sqlite3 .local.db '' && find migrations -name '*.sql' -print | sort | while read -r file; do sqlite3 .local.db < \"$file\"; done",
    "db:types": "pnpm run db:rebuild && tsx ./scripts/generate-queries.ts --force",
    "db:types:stale": "tsx ./scripts/generate-queries.ts --if-stale",
    "db:watch": "pnpm run db:rebuild && tsx ./scripts/generate-queries.ts --watch"
  },
  "iterateAppCli": {
    "remote": {
      "defaultBaseUrl": "https://semaphore.iterate.com",
      "auth": "shared-api-secret-bearer"
    }
  },
  "dependencies": {
    "@iterate-com/semaphore-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@orpc/client": "1.13.14",
    "@orpc/openapi": "1.13.14",
    "@orpc/openapi-client": "1.13.14",
    "@orpc/server": "1.13.14",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "1.168.3",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "1.167.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.83.3",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typesql-cli": "github:iterate/typesql#5687eb2",
    "vite": "^8.0.0",
    "vitest": "4.0.15",
    "wrangler": "^4.75.0"
  }
}
