{
  "include": ["**/*.ts", "**/*.tsx", "raw-sql.d.ts", "alchemy.run.ts"],
  "compilerOptions": {
    "target": "ES2024",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "~/*": ["./src/*"],
      "@iterate-com/ui/*": ["../../packages/ui/src/*"],
      "@iterate-com/shared/*": ["../../packages/shared/src/*"],
      "@iterate-com/shared/posthog/vite-plugin": [
        "../../packages/shared/src/posthog/sourcemaps-vite-plugin.ts"
      ]
    },
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": [
      "vite/client",
      "node",
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers"
    ],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true
  }
}
