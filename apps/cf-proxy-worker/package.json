{
  "name": "@iterate-com/cf-proxy-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "doppler run --config dev -- sh -c 'APP_STAGE=dev tsx ./alchemy.run.ts cli --dev --stage \"$APP_STAGE\"'",
    "deploy:prd": "doppler run --config prd -- sh -c 'APP_STAGE=prd tsx ./alchemy.run.ts cli deploy --stage \"$APP_STAGE\"'",
    "deploy": "pnpm run deploy:prd",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orpc/server": "^1.13.4",
    "alchemy": "^0.83.0",
    "hono": "^4.11.3",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.17",
    "@cloudflare/workers-types": "^4.20260207.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "3.2.4",
    "wrangler": "^4.64.0"
  }
}
