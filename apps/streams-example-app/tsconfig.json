{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["@cloudflare/workers-types", "node", "vite/client", "vitest"],
    "paths": {
      // Exact-match shim: see src/os-shims/request-context.ts for why apps/os's
      // request-context module (and its TanStack Register augmentations) must
      // stay out of this app's program.
      "~/request-context.ts": ["./src/os-shims/request-context.ts"],
      "~/*": ["../os/src/*"],
      "@iterate-com/shared/*": ["../../packages/shared/src/*"]
    }
  },
  // The next engine sources under ../os/src/next are pulled in transitively via
  // the `~` alias imports, so they do not need explicit include entries.
  "include": ["src/**/*.ts", "src/**/*.tsx", "e2e/**/*.ts"],
  "exclude": ["test-quarantine/**"]
}
