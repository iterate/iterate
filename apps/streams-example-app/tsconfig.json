{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["@cloudflare/workers-types", "node", "vite/client", "vitest"],
    "paths": {
      "~/*": ["../os/src/*"],
      "@iterate-com/shared/*": ["../../packages/shared/src/*"]
    }
  },
  // The apps/os sources under ../os/src are pulled in transitively via
  // the `~` alias imports, so they do not need explicit include entries.
  "include": ["src/**/*.ts", "src/**/*.tsx", "e2e/**/*.ts"],
  "exclude": []
}
