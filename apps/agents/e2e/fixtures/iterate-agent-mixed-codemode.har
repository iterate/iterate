            "text": "{\"jsonrpc\":\"2.0\",\"id\":1,\"result\":{\"tools\":[{\"name\":\"canuckduck_search\",\"description\":\"\\n    Search for Canadian policy variables in the RIPPLE causal graph.\\n\\n    Returns variables matching the query with their var_id, label, category,\\n    description, baseline value, and tier classification. Always run this first\\n    to find the correct variable label before using traversal tools.\\n\\n    Args:\\n        params (SearchInput): Search parameters containing:\\n            - query (str): Search term (e.g., 'housing affordability', 'DND')\\n            - limit (int): Max results, default 10\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON list of matching variables with var_id, label, category,\\n             description, baseline, target, unit, and tier fields.\\n    \",\"inputSchema\":{\"$defs\":{\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"},\"SearchInput\":{\"additionalProperties\":false,\"description\":\"Input for variable search.\",\"properties\":{\"query\":{\"description\":\"Search term. Searches variable labels, IDs, and descriptions. Examples: 'housing', 'defence spending', 'carbon tax', 'arctic'\",\"maxLength\":200,\"minLength\":1,\"title\":\"Query\",\"type\":\"string\"},\"limit\":{\"default\":10,\"description\":\"Maximum results to return (1-50)\",\"maximum\":50,\"minimum\":1,\"title\":\"Limit\",\"type\":\"integer\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' for readable output, 'json' for structured data\"}},\"required\":[\"query\"],\"title\":\"SearchInput\",\"type\":\"object\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/SearchInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_searchArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_searchOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Search RIPPLE Policy Variables\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_stats\",\"description\":\"\\n    Get summary statistics for the CanuckDUCK RIPPLE causal knowledge graph.\\n\\n    Returns total variable count, edge count, category breakdown, top variables\\n    by connectivity, and data freshness indicators. Use this to understand\\n    the scope of the graph before running traversals.\\n\\n    Args:\\n        params (StatsInput): Optional format parameter.\\n\\n    Returns:\\n        str: JSON with total_variables, total_edges, categories, top_variables,\\n             last_updated, and graph_health fields.\\n    \",\"inputSchema\":{\"$defs\":{\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"},\"StatsInput\":{\"additionalProperties\":false,\"description\":\"Input for graph statistics.\",\"properties\":{\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' for readable output, 'json' for structured data\"}},\"title\":\"StatsInput\",\"type\":\"object\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/StatsInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_statsArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_statsOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"RIPPLE Graph Statistics\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_forward\",\"description\":\"\\n    Trace what a policy variable causes -- follow causal chains forward.\\n\\n    Discovers downstream effects of a variable through CAUSES relationships.\\n    Each path shows the chain of variables affected, relationship strengths,\\n    confidence scores, and causal direction. Use this to understand the\\n    policy consequences of changes to a variable.\\n\\n    Requires: X-API-Key header with a registered or professional key.\\n\\n    Args:\\n        params (ForwardInput): Traversal parameters containing:\\n            - variable (str): Starting variable label\\n            - max_depth (int): Hops to traverse (1-5, default 3)\\n            - direction_filter: 'positive', 'negative', or 'all'\\n            - min_confidence (float): Edge confidence threshold (0.0-1.0)\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with source variable, paths array (each path has nodes[],\\n             relationships[] with strength/confidence/direction/source),\\n             and summary statistics.\\n    \",\"inputSchema\":{\"$defs\":{\"DirectionFilter\":{\"description\":\"Filter causal relationships by direction.\",\"enum\":[\"positive\",\"negative\",\"all\"],\"title\":\"DirectionFilter\",\"type\":\"string\"},\"ForwardInput\":{\"additionalProperties\":false,\"description\":\"Input for forward causal traversal.\",\"properties\":{\"variable\":{\"description\":\"Label of the variable to trace forward from. Use canuckduck_search first to get the exact label. Examples: 'Defence Spending (DND)', 'Housing Affordability Index'\",\"maxLength\":200,\"minLength\":1,\"title\":\"Variable\",\"type\":\"string\"},\"max_depth\":{\"default\":3,\"description\":\"Maximum hops to traverse (1-5). Deeper = more paths, slower response.\",\"maximum\":5,\"minimum\":1,\"title\":\"Max Depth\",\"type\":\"integer\"},\"direction_filter\":{\"$ref\":\"#/$defs/DirectionFilter\",\"default\":\"all\",\"description\":\"Filter by causal direction: 'positive' (increases), 'negative' (decreases), or 'all'\"},\"min_confidence\":{\"default\":0,\"description\":\"Minimum confidence threshold (0.0-1.0). Higher = more validated edges only.\",\"maximum\":1,\"minimum\":0,\"title\":\"Min Confidence\",\"type\":\"number\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' for readable output, 'json' for structured data\"}},\"required\":[\"variable\"],\"title\":\"ForwardInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/ForwardInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_forwardArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_forwardOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Trace Forward Causal Chain\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_backward\",\"description\":\"\\n    Trace what causes a policy variable -- follow causal chains backward.\\n\\n    Discovers upstream drivers of a variable. Use this to understand\\n    root causes of a policy outcome, or to identify which levers most\\n    directly influence a target variable.\\n\\n    Requires: X-API-Key header with a registered or professional key.\\n\\n    Args:\\n        params (BackwardInput): Traversal parameters containing:\\n            - variable (str): Target variable label to trace backward from\\n            - max_depth (int): Hops to traverse backward (1-5, default 3)\\n            - min_confidence (float): Edge confidence threshold\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with target variable, upstream paths array, and\\n             frequency map of most common root causes.\\n    \",\"inputSchema\":{\"$defs\":{\"BackwardInput\":{\"additionalProperties\":false,\"description\":\"Input for backward causal traversal.\",\"properties\":{\"variable\":{\"description\":\"Label of the variable to trace backward from -- find its causes. Examples: 'Public Trust Index', 'Housing Affordability Index'\",\"maxLength\":200,\"minLength\":1,\"title\":\"Variable\",\"type\":\"string\"},\"max_depth\":{\"default\":3,\"description\":\"Maximum hops to traverse backward (1-5)\",\"maximum\":5,\"minimum\":1,\"title\":\"Max Depth\",\"type\":\"integer\"},\"min_confidence\":{\"default\":0,\"description\":\"Minimum confidence threshold (0.0-1.0)\",\"maximum\":1,\"minimum\":0,\"title\":\"Min Confidence\",\"type\":\"number\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"variable\"],\"title\":\"BackwardInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/BackwardInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_backwardArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_backwardOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Trace Backward Causal Chain\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_paths\",\"description\":\"\\n    Find all causal paths connecting two Canadian policy variables.\\n\\n    Discovers how one variable relates to another through chains of\\n    CAUSES edges. Returns all paths sorted by cumulative edge strength,\\n    with a frequency map of the most critical intermediate transmission\\n    nodes. Use this to validate causal theories or find indirect\\n    policy mechanisms.\\n\\n    Example: defence_spending → public_trust_index yields 1,803 paths\\n    across 3 hops, with Business Investment as the #1 transmission node.\\n\\n    Requires: X-API-Key header with a registered or professional key.\\n\\n    Args:\\n        params (PathsInput): Path parameters containing:\\n            - from_variable (str): Starting variable label\\n            - to_variable (str): Target variable label\\n            - max_depth (int): Max path length (1-7, default 5)\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with path_count, hop_counts by depth, paths array,\\n             and intermediates frequency map showing critical nodes.\\n    \",\"inputSchema\":{\"$defs\":{\"PathsInput\":{\"additionalProperties\":false,\"description\":\"Input for finding causal paths between two variables.\",\"properties\":{\"from_variable\":{\"description\":\"Starting variable label. Use canuckduck_search to find exact labels.\",\"maxLength\":200,\"minLength\":1,\"title\":\"From Variable\",\"type\":\"string\"},\"to_variable\":{\"description\":\"Target variable label.\",\"maxLength\":200,\"minLength\":1,\"title\":\"To Variable\",\"type\":\"string\"},\"max_depth\":{\"default\":5,\"description\":\"Maximum path length in hops (1-7). Longer paths reveal indirect relationships.\",\"maximum\":7,\"minimum\":1,\"title\":\"Max Depth\",\"type\":\"integer\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"from_variable\",\"to_variable\"],\"title\":\"PathsInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/PathsInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_pathsArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_pathsOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Find Causal Paths Between Variables\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_impact\",\"description\":\"\\n    Analyze the full impact radius of a Canadian policy variable.\\n\\n    Returns a comprehensive view of all variables affected by changes\\n    to the target variable, grouped by causal distance, direction,\\n    and strength. Includes a summary of total downstream reach and\\n    the most critical transmission pathways.\\n\\n    Use this for high-level policy impact assessment before commissioning\\n    a detailed Tribunal Review.\\n\\n    Requires: X-API-Key header with a registered or professional key.\\n\\n    Args:\\n        params (ImpactInput): Impact parameters containing:\\n            - variable (str): Variable label to analyze\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with variable details, direct_effects, indirect_effects\\n             by hop depth, total_reach count, and strength_weighted_impact score.\\n    \",\"inputSchema\":{\"$defs\":{\"ImpactInput\":{\"additionalProperties\":false,\"description\":\"Input for full impact radius analysis.\",\"properties\":{\"variable\":{\"description\":\"Variable label to analyze impact for. Example: 'Federal Budget Balance', 'Arctic Sovereignty'\",\"maxLength\":200,\"minLength\":1,\"title\":\"Variable\",\"type\":\"string\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"variable\"],\"title\":\"ImpactInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/ImpactInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_impactArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_impactOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Analyze Full Impact Radius\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_evidence\",\"description\":\"\\n    Retrieve the source evidence and community observations behind a\\n    RIPPLE causal variable.\\n\\n    Returns CausalChain nodes linked to the variable, the RippleComment\\n    observations they were extracted from, and the evidence type\\n    (community observation, academic source, federal data, AI-extracted).\\n\\n    Use this to audit the evidence base of a policy variable before\\n    citing it in research or policy documents.\\n\\n    Requires: X-API-Key header with a registered or professional key.\\n\\n    Args:\\n        params (EvidenceInput): Evidence parameters containing:\\n            - variable (str): Variable label to find evidence for\\n            - limit (int): Max evidence chains to return (default 10)\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with variable details and evidence_chains array, each\\n             chain containing source_comment, extracted_relationship,\\n             confidence, and evidence_type fields.\\n    \",\"inputSchema\":{\"$defs\":{\"EvidenceInput\":{\"additionalProperties\":false,\"description\":\"Input for retrieving source evidence.\",\"properties\":{\"variable\":{\"description\":\"Variable label to find source evidence for. Returns the causal chains and community observations that ground this variable in the RIPPLE graph.\",\"maxLength\":200,\"minLength\":1,\"title\":\"Variable\",\"type\":\"string\"},\"limit\":{\"default\":10,\"description\":\"Maximum evidence chains to return (1-50)\",\"maximum\":50,\"minimum\":1,\"title\":\"Limit\",\"type\":\"integer\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"variable\"],\"title\":\"EvidenceInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/EvidenceInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_evidenceArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_evidenceOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Get Source Evidence for Variable\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_news\",\"description\":\"\\n    Search news articles ingested from Canadian government and media RSS feeds.\\n\\n    Returns articles relevant to a policy query, drawn from sources including\\n    federal government announcements, CBC, Globe and Mail, and provincial\\n    government releases. Articles are tagged to RIPPLE variables where\\n    mappings exist.\\n\\n    Use this to find real-world signal that complements the causal graph --\\n    what is actually being reported versus what the graph predicts.\\n\\n    Requires: X-API-Key header with a registered or professional key.\\n\\n    Args:\\n        params (NewsInput): News search parameters containing:\\n            - query (str): Search term for Canadian news\\n            - limit (int): Max articles to return (default 10)\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with articles array, each containing title, source,\\n             published_at, summary, url, and ripple_variables[] tags.\\n    \",\"inputSchema\":{\"$defs\":{\"NewsInput\":{\"additionalProperties\":false,\"description\":\"Input for searching Canadian news articles.\",\"properties\":{\"query\":{\"description\":\"Search query for Canadian news. Searches articles ingested from Canadian government and media RSS feeds. Examples: 'Arctic sovereignty', 'housing affordability BC', 'DND spending NATO'\",\"maxLength\":200,\"minLength\":1,\"title\":\"Query\",\"type\":\"string\"},\"limit\":{\"default\":10,\"description\":\"Maximum articles to return (1-25)\",\"maximum\":25,\"minimum\":1,\"title\":\"Limit\",\"type\":\"integer\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"query\"],\"title\":\"NewsInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/NewsInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_newsArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_newsOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Search Canadian Policy News\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_constitutional\",\"description\":\"\\n    Explore Canadian constitutional doctrines mapped in the RIPPLE graph.\\n\\n    Returns constitutional authorities, their jurisdictional scope, and\\n    the RIPPLE variables they constrain. Includes CDA (Constitutional\\n    Divergence Analysis) severity ratings for each doctrine-variable pair.\\n\\n    Use this to understand the constitutional framing of a policy domain\\n    before analysis -- particularly relevant for Indigenous sovereignty,\\n    fiscal federalism, and national security questions.\\n\\n    Requires: X-API-Key header with a professional key (cduck_p_*).\\n\\n    Args:\\n        params (ConstitutionalInput): Parameters containing:\\n            - doctrine (str, optional): Specific doctrine name, or empty for all\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with doctrines array, each containing name, jurisdiction,\\n             constitutional_basis, constrained_variables[], and cda_severity.\\n    \",\"inputSchema\":{\"$defs\":{\"ConstitutionalInput\":{\"additionalProperties\":false,\"description\":\"Input for constitutional doctrine exploration.\",\"properties\":{\"doctrine\":{\"anyOf\":[{\"maxLength\":200,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Constitutional doctrine name to explore. Leave empty to list all available doctrines. Examples: 'Peace Order and Good Government', 'Section 35 Aboriginal Rights', 'Division of Powers'\",\"title\":\"Doctrine\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"title\":\"ConstitutionalInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/ConstitutionalInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_constitutionalArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_constitutionalOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Explore Constitutional Doctrines\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_root_trace\",\"description\":\"\\n    Trace a Canadian policy variable back to its constitutional roots.\\n\\n    For a given variable, finds which constitutional authorities CONSTRAIN it,\\n    what CDA (Constitutional Divergence Analysis) flags and dimensions are\\n    involved, the severity of each constitutional relationship, and whether\\n    current policy is aligned or divergent from constitutional requirements.\\n\\n    Use this for legal research, constitutional challenge assessment, or\\n    understanding why a policy variable has structural constraints that\\n    cannot be addressed by ordinary legislation.\\n\\n    Requires: X-API-Key header with a professional key (cduck_p_*).\\n\\n    Args:\\n        params (RootTraceInput): Parameters containing:\\n            - variable (str): Policy variable label to trace\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with variable details, constitutional_roots array (each with\\n             authority, basis, cda_dimensions[], severity, alignment_status),\\n             and overall constitutional_risk_score.\\n    \",\"inputSchema\":{\"$defs\":{\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"},\"RootTraceInput\":{\"additionalProperties\":false,\"description\":\"Input for tracing a variable to constitutional roots.\",\"properties\":{\"variable\":{\"description\":\"Policy variable label to trace to constitutional roots. Examples: 'Healthcare Wait Times', 'Arctic Sovereignty', 'Indigenous Wellbeing Index'\",\"maxLength\":200,\"minLength\":1,\"title\":\"Variable\",\"type\":\"string\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"variable\"],\"title\":\"RootTraceInput\",\"type\":\"object\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/RootTraceInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_root_traceArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_root_traceOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Trace Variable to Constitutional Roots\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_cda_profile\",\"description\":\"\\n    Look up the Constitutional Divergence Analysis (CDA) profile for a\\n    Pond forum topic.\\n\\n    Returns the CDA dimensions flagged for a specific civic discussion,\\n    the constitutional authorities involved, divergence severity ratings,\\n    and recommended policy alignment pathways.\\n\\n    CDA profiles are generated by the AI Tribunal during Tribunal Review\\n    sessions and represent the most rigorous constitutional analysis\\n    available on the platform.\\n\\n    Requires: X-API-Key header with a professional key (cduck_p_*).\\n\\n    Args:\\n        params (CdaProfileInput): Parameters containing:\\n            - topic_id (int): Pond forum topic ID\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with topic details, cda_dimensions[] (each with name,\\n             authority, severity, divergence_type, alignment_pathway),\\n             overall_cda_score, and tribunal_session references.\\n    \",\"inputSchema\":{\"$defs\":{\"CdaProfileInput\":{\"additionalProperties\":false,\"description\":\"Input for CDA profile lookup.\",\"properties\":{\"topic_id\":{\"anyOf\":[{\"minimum\":1,\"type\":\"integer\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Pond forum topic ID (optional). Get topic IDs from pond.canuckduck.ca.\",\"title\":\"Topic Id\"},\"keywords\":{\"anyOf\":[{\"maxLength\":200,\"minLength\":2,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Keywords to search for a CDA profile (e.g. 'housing affordability', 'arctic sovereignty'). Use this if you don't have a topic ID.\",\"title\":\"Keywords\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"title\":\"CdaProfileInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/CdaProfileInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_cda_profileArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_cda_profileOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Get CDA Profile for Forum Topic\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_simulate\",\"description\":\"\\n    Run a multi-variable policy scenario simulation on the RIPPLE causal graph.\\n\\n    Model what happens when multiple policy variables change simultaneously.\\n    Returns cascading impacts with projected values (where baselines exist),\\n    constitutional constraint warnings, and source attribution.\\n\\n    Example scenario: What if BoC cuts rates 0.25% AND federal spending\\n    increases 5%?\\n      scenario: [{\\\"var_id\\\":\\\"interest_rate\\\",\\\"delta\\\":-0.25},{\\\"var_id\\\":\\\"federal_spending\\\",\\\"delta\\\":5}]\\n\\n    Requires: X-API-Key header with a professional key (cduck_p_*).\\n\\n    Args:\\n        params (ScenarioInput): Parameters containing:\\n            - scenario: JSON array of {var_id, delta} objects\\n            - depth: propagation depth (1-3, default 2)\\n            - response_format: 'markdown' or 'json'\\n\\n    Returns:\\n        str: JSON with impacts[] (var_id, label, baseline, projected_value,\\n             estimated_impact_percent, sources[]), constitutional_warnings[],\\n             total_affected count, and scenario_inputs echo.\\n    \",\"inputSchema\":{\"$defs\":{\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"},\"ScenarioInput\":{\"additionalProperties\":false,\"properties\":{\"scenario\":{\"description\":\"JSON array of scenario inputs. Each entry: {\\\"var_id\\\": \\\"interest_rate\\\", \\\"delta\\\": -0.25}. Delta is a signed percentage change.\",\"title\":\"Scenario\",\"type\":\"string\"},\"depth\":{\"default\":2,\"description\":\"Propagation depth (1=direct, 2=indirect, 3=deep)\",\"maximum\":3,\"minimum\":1,\"title\":\"Depth\",\"type\":\"integer\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"json\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"scenario\"],\"title\":\"ScenarioInput\",\"type\":\"object\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/ScenarioInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_simulateArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_simulateOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Run Policy Scenario Simulation\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_geo_lookup\",\"description\":\"\\n    Look up geographic context for a Canadian postal code or FSA code.\\n\\n    Returns the community name, city, province, and coordinates for any\\n    Canadian postal code. Use the full 6-character postal code (e.g.,\\n    'T2P3H5') for community-level precision, or the 3-character FSA\\n    prefix (e.g., 'T2P') for area-level lookup.\\n\\n    Example: 'T2P 3H5' returns 'Downtown Commercial Core, Calgary, AB'\\n    with lat/lon coordinates.\\n\\n    No API key required — this is a public lookup tool.\\n    \",\"inputSchema\":{\"$defs\":{\"GeoLookupInput\":{\"additionalProperties\":false,\"properties\":{\"postal_code\":{\"description\":\"Canadian postal code (e.g., 'T2P 3H5') or 3-character FSA code (e.g., 'T2P'). Returns community, city, province, and coordinates.\",\"maxLength\":7,\"minLength\":3,\"title\":\"Postal Code\",\"type\":\"string\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"markdown\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"postal_code\"],\"title\":\"GeoLookupInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/GeoLookupInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_geo_lookupArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_geo_lookupOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Look Up Canadian Postal Code / Community\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_geo_variables\",\"description\":\"\\n    Find RIPPLE causal graph variables scoped to a specific Canadian\\n    province. Returns both province-specific variables (e.g.,\\n    'alberta_gdp', 'ontario_population') and national variables that\\n    apply everywhere.\\n\\n    Use this to understand which policy variables are relevant to a\\n    particular province before running a localized scenario.\\n\\n    Requires: X-API-Key header with a registered key (cduck_r_*).\\n    \",\"inputSchema\":{\"$defs\":{\"GeoVariablesInput\":{\"additionalProperties\":false,\"properties\":{\"province\":{\"anyOf\":[{\"maxLength\":2,\"minLength\":2,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"2-character province code (ON, AB, BC, QC, SK, MB, NS, NB, NL, PE, YT, NT, NU)\",\"title\":\"Province\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"json\",\"description\":\"'markdown' or 'json'\"}},\"title\":\"GeoVariablesInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/GeoVariablesInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_geo_variablesArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_geo_variablesOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Get Policy Variables for a Canadian Province\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_local_impact\",\"description\":\"\\n    Run a policy scenario simulation and localize the impacts to a\\n    specific Canadian community.\\n\\n    Combines RIPPLE causal graph propagation with geographic scoping\\n    to answer: 'What does this policy change mean for YOUR community?'\\n\\n    First resolves the postal code to a province, then runs the scenario\\n    and filters results to show geographic relevance — provincial\\n    variables for that region are marked as 'direct', national variables\\n    as 'indirect'.\\n\\n    Example: postal_code='T2P', scenario=[{\\\"var_id\\\":\\\"interest_rate\\\",\\\"delta\\\":-5}]\\n    Returns Calgary-relevant impacts with local context.\\n\\n    Requires: X-API-Key header with a registered key (cduck_r_*).\\n    \",\"inputSchema\":{\"$defs\":{\"LocalImpactInput\":{\"additionalProperties\":false,\"properties\":{\"postal_code\":{\"description\":\"Canadian postal code or FSA to localize impact for (e.g., 'T2P' for Calgary downtown)\",\"maxLength\":7,\"minLength\":3,\"title\":\"Postal Code\",\"type\":\"string\"},\"scenario\":{\"description\":\"JSON array of scenario inputs: [{\\\"var_id\\\": \\\"interest_rate\\\", \\\"delta\\\": -5}]\",\"title\":\"Scenario\",\"type\":\"string\"},\"depth\":{\"default\":2,\"description\":\"Propagation depth (1=direct, 2=indirect, 3=deep)\",\"maximum\":3,\"minimum\":1,\"title\":\"Depth\",\"type\":\"integer\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"json\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"postal_code\",\"scenario\"],\"title\":\"LocalImpactInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/LocalImpactInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_local_impactArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_local_impactOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Localized Policy Impact Simulation\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_geo_stats\",\"description\":\"\\n    Get geographic data coverage statistics for the CanuckDUCK platform.\\n\\n    Returns counts of FSA codes, census subdivisions (municipalities),\\n    census metropolitan areas, federal ridings, communities, and postal\\n    codes mapped. Also shows variable-to-geography mapping breakdown.\\n\\n    No API key required.\\n    \",\"inputSchema\":{\"$defs\":{\"GeoStatsInput\":{\"additionalProperties\":false,\"properties\":{\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"json\",\"description\":\"'markdown' or 'json'\"}},\"title\":\"GeoStatsInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/GeoStatsInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_geo_statsArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_geo_statsOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Geographic Data Coverage Statistics\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_propose\",\"description\":\"\\n    Propose a new variable, causal edge, or evidence to the RIPPLE graph.\\n\\n    All proposals enter a review queue -- nothing modifies the active graph\\n    until a human reviewer approves. Use this to contribute knowledge that\\n    fills gaps in the Canadian policy causal model.\\n\\n    Three proposal types:\\n    - 'variable': New policy variable with evidence sources\\n    - 'edge': New CAUSES relationship between existing variables\\n    - 'evidence': New evidence for an existing causal relationship\\n\\n    Requires: API key (registered cduck_r_* or professional cduck_p_*).\\n    Rate limits: 5-20 proposals/hour depending on type and key tier.\\n    \",\"inputSchema\":{\"$defs\":{\"ProposeEdgePayload\":{\"additionalProperties\":false,\"properties\":{\"source_var_id\":{\"description\":\"Source variable ID (must exist). Use canuckduck_search to find.\",\"maxLength\":100,\"minLength\":3,\"title\":\"Source Var Id\",\"type\":\"string\"},\"target_var_id\":{\"description\":\"Target variable ID (must exist). The variable CAUSED by the source.\",\"maxLength\":100,\"minLength\":3,\"title\":\"Target Var Id\",\"type\":\"string\"},\"direction\":{\"description\":\"'positive' or 'negative'\",\"pattern\":\"^(positive|negative)$\",\"title\":\"Direction\",\"type\":\"string\"},\"strength\":{\"description\":\"Causal strength (1-100)\",\"maximum\":100,\"minimum\":1,\"title\":\"Strength\",\"type\":\"integer\"},\"confidence\":{\"description\":\"Confidence (0.0-1.0). 1.0=accounting identity, 0.5=theoretical.\",\"maximum\":1,\"minimum\":0,\"title\":\"Confidence\",\"type\":\"number\"},\"evidence_type\":{\"description\":\"Evidence type: empirical, accounting, policy, academic, structural, theoretical, statistical, government_report, legal, model\",\"title\":\"Evidence Type\",\"type\":\"string\"},\"evidence_source\":{\"description\":\"Citation or URL\",\"maxLength\":500,\"minLength\":5,\"title\":\"Evidence Source\",\"type\":\"string\"},\"mechanism\":{\"description\":\"HOW and WHY the relationship works. Min 30 chars.\",\"maxLength\":1000,\"minLength\":30,\"title\":\"Mechanism\",\"type\":\"string\"},\"delay_real_months\":{\"anyOf\":[{\"maximum\":120,\"minimum\":0,\"type\":\"integer\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Months before effect manifests\",\"title\":\"Delay Real Months\"}},\"required\":[\"source_var_id\",\"target_var_id\",\"direction\",\"strength\",\"confidence\",\"evidence_type\",\"evidence_source\",\"mechanism\"],\"title\":\"ProposeEdgePayload\",\"type\":\"object\"},\"ProposeEvidencePayload\":{\"additionalProperties\":false,\"properties\":{\"source_var_id\":{\"description\":\"Source variable of the existing edge\",\"maxLength\":100,\"minLength\":3,\"title\":\"Source Var Id\",\"type\":\"string\"},\"target_var_id\":{\"description\":\"Target variable of the existing edge\",\"maxLength\":100,\"minLength\":3,\"title\":\"Target Var Id\",\"type\":\"string\"},\"evidence_type\":{\"description\":\"Type of new evidence\",\"title\":\"Evidence Type\",\"type\":\"string\"},\"evidence_source\":{\"description\":\"Citation or URL\",\"maxLength\":500,\"minLength\":5,\"title\":\"Evidence Source\",\"type\":\"string\"},\"confidence_update\":{\"anyOf\":[{\"maximum\":1,\"minimum\":0,\"type\":\"number\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Suggested new confidence\",\"title\":\"Confidence Update\"},\"accuracy_observation\":{\"anyOf\":[{\"maxLength\":1000,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Observed outcome vs predicted\",\"title\":\"Accuracy Observation\"},\"source_url\":{\"anyOf\":[{\"maxLength\":500,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"URL to source document\",\"title\":\"Source Url\"}},\"required\":[\"source_var_id\",\"target_var_id\",\"evidence_type\",\"evidence_source\"],\"title\":\"ProposeEvidencePayload\",\"type\":\"object\"},\"ProposeInput\":{\"additionalProperties\":false,\"description\":\"Submit a proposed variable, edge, or evidence to the RIPPLE graph review queue.\",\"properties\":{\"proposal_type\":{\"description\":\"'variable', 'edge', or 'evidence'\",\"pattern\":\"^(variable|edge|evidence)$\",\"title\":\"Proposal Type\",\"type\":\"string\"},\"variable\":{\"anyOf\":[{\"$ref\":\"#/$defs/ProposeVariablePayload\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Required when proposal_type='variable'\"},\"edge\":{\"anyOf\":[{\"$ref\":\"#/$defs/ProposeEdgePayload\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Required when proposal_type='edge'\"},\"evidence\":{\"anyOf\":[{\"$ref\":\"#/$defs/ProposeEvidencePayload\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Required when proposal_type='evidence'\"},\"proposal_context\":{\"anyOf\":[{\"maxLength\":1000,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Why this proposal matters\",\"title\":\"Proposal Context\"}},\"required\":[\"proposal_type\"],\"title\":\"ProposeInput\",\"type\":\"object\"},\"ProposeVariablePayload\":{\"additionalProperties\":false,\"properties\":{\"var_id\":{\"description\":\"Variable ID (snake_case). Must not already exist.\",\"maxLength\":100,\"minLength\":3,\"pattern\":\"^[a-z][a-z0-9_]*$\",\"title\":\"Var Id\",\"type\":\"string\"},\"label\":{\"description\":\"Human-readable variable name\",\"maxLength\":200,\"minLength\":5,\"title\":\"Label\",\"type\":\"string\"},\"description\":{\"description\":\"Evidence-grounded description. Minimum 50 characters.\",\"maxLength\":2000,\"minLength\":50,\"title\":\"Description\",\"type\":\"string\"},\"category\":{\"description\":\"Variable category: fiscal, economic, financial, demographic, environmental, governance, infrastructure, operational, social, security, health, education, cultural\",\"title\":\"Category\",\"type\":\"string\"},\"unit\":{\"description\":\"Unit of measurement\",\"maxLength\":50,\"minLength\":1,\"title\":\"Unit\",\"type\":\"string\"},\"baseline_value\":{\"description\":\"Current or initial value\",\"title\":\"Baseline Value\",\"type\":\"number\"},\"jurisdiction\":{\"anyOf\":[{\"maxLength\":10,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"2-letter province code, 'federal', or null\",\"title\":\"Jurisdiction\"},\"evidence_sources\":{\"description\":\"At least one evidence source (URL or citation)\",\"items\":{\"type\":\"string\"},\"minItems\":1,\"title\":\"Evidence Sources\",\"type\":\"array\"}},\"required\":[\"var_id\",\"label\",\"description\",\"category\",\"unit\",\"baseline_value\",\"evidence_sources\"],\"title\":\"ProposeVariablePayload\",\"type\":\"object\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/ProposeInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_proposeArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_proposeOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Propose Graph Contribution\",\"readOnlyHint\":false,\"destructiveHint\":false,\"idempotentHint\":false,\"openWorldHint\":true}},{\"name\":\"canuckduck_review_queue\",\"description\":\"\\n    List pending graph proposals, check status, or approve/reject.\\n\\n    - 'list': Show proposals in the review queue (filterable by type, status)\\n    - 'status': Check a specific proposal by UUID\\n    - 'decide': Approve or reject (requires professional API key)\\n\\n    Approved proposals are applied to the active RIPPLE graph by admins.\\n\\n    Requires: Registered key for list/status, Professional for decide.\\n    \",\"inputSchema\":{\"$defs\":{\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"},\"ReviewQueueInput\":{\"additionalProperties\":false,\"description\":\"List, check, or decide on graph proposals.\",\"properties\":{\"action\":{\"description\":\"'list', 'status', or 'decide' (decide requires professional key)\",\"pattern\":\"^(list|status|decide)$\",\"title\":\"Action\",\"type\":\"string\"},\"proposal_id\":{\"anyOf\":[{\"maxLength\":36,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Proposal UUID for status/decide\",\"title\":\"Proposal Id\"},\"decision\":{\"anyOf\":[{\"pattern\":\"^(approve|reject)$\",\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"'approve' or 'reject'\",\"title\":\"Decision\"},\"review_notes\":{\"anyOf\":[{\"maxLength\":1000,\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Notes (required for reject)\",\"title\":\"Review Notes\"},\"filters\":{\"anyOf\":[{\"additionalProperties\":true,\"type\":\"object\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"For 'list': {proposal_type, status, limit}\",\"title\":\"Filters\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"json\",\"description\":\"'markdown' or 'json'\"}},\"required\":[\"action\"],\"title\":\"ReviewQueueInput\",\"type\":\"object\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/ReviewQueueInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_review_queueArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_review_queueOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Review Graph Proposals\",\"readOnlyHint\":false,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}},{\"name\":\"canuckduck_gaps\",\"description\":\"\\n    Query the RIPPLE Observatory for detected graph gaps and health metrics.\\n\\n    The observatory passively monitors all MCP requests to identify where\\n    the graph is deficient: search misses, disconnected paths, simulation\\n    anomalies, evidence voids, and constitutional gaps.\\n\\n    Report types:\\n    - 'summary': Graph health score + top gaps ranked by priority\\n    - 'search_misses': Concepts users search for but the graph lacks\\n    - 'path_failures': Variable pairs users expect to be connected but aren't\\n    - 'calibration': Simulation outputs that are statistically anomalous\\n    - 'evidence_voids': Edges lacking supporting evidence\\n    - 'constitutional': Policy variables missing constitutional mapping\\n    - 'full': All of the above\\n\\n    Requires: Professional API key (cduck_p_*).\\n    \",\"inputSchema\":{\"$defs\":{\"GapsInput\":{\"additionalProperties\":false,\"description\":\"Query the RIPPLE Observatory gap analysis.\",\"properties\":{\"report_type\":{\"default\":\"summary\",\"description\":\"'summary' (overview + top gaps), 'search_misses', 'path_failures', 'calibration', 'evidence_voids', 'constitutional', or 'full'\",\"pattern\":\"^(summary|search_misses|path_failures|calibration|evidence_voids|constitutional|full)$\",\"title\":\"Report Type\",\"type\":\"string\"},\"severity_filter\":{\"anyOf\":[{\"pattern\":\"^(critical|high|medium|low)$\",\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Filter by severity: 'critical', 'high', 'medium', 'low'\",\"title\":\"Severity Filter\"},\"category_filter\":{\"anyOf\":[{\"type\":\"string\"},{\"type\":\"null\"}],\"default\":null,\"description\":\"Filter by RIPPLE category\",\"title\":\"Category Filter\"},\"limit\":{\"default\":20,\"description\":\"Max gaps to return\",\"maximum\":100,\"minimum\":1,\"title\":\"Limit\",\"type\":\"integer\"},\"response_format\":{\"$ref\":\"#/$defs/ResponseFormat\",\"default\":\"json\",\"description\":\"'markdown' or 'json'\"}},\"title\":\"GapsInput\",\"type\":\"object\"},\"ResponseFormat\":{\"description\":\"Output format for tool responses.\",\"enum\":[\"markdown\",\"json\"],\"title\":\"ResponseFormat\",\"type\":\"string\"}},\"properties\":{\"params\":{\"$ref\":\"#/$defs/GapsInput\"}},\"required\":[\"params\"],\"title\":\"canuckduck_gapsArguments\",\"type\":\"object\"},\"outputSchema\":{\"properties\":{\"result\":{\"title\":\"Result\",\"type\":\"string\"}},\"required\":[\"result\"],\"title\":\"canuckduck_gapsOutput\",\"type\":\"object\"},\"annotations\":{\"title\":\"Observatory Gap Analysis\",\"readOnlyHint\":true,\"destructiveHint\":false,\"idempotentHint\":true,\"openWorldHint\":false}}]}}"
          },
