{
  "name": "@iterate-com/agents",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "~/*": "./src/*"
  },
  "scripts": {
    "alchemy:up": "tsx ./alchemy.run.ts",
    "alchemy:down": "tsx ./alchemy.run.ts --destroy",
    "cli": "doppler run --no-cache -- iterate-app-cli",
    "dev": "doppler run --no-cache -- tsx ./alchemy.run.ts",
    "dev:local-events": "doppler run --no-cache -- env APP_CONFIG_EVENTS_BASE_URL=http://localhost:5173 tsx ./alchemy.run.ts",
    "build": "doppler run --no-cache -- pnpm exec vite build",
    "deploy": "doppler run --no-cache --config prd -- pnpm alchemy:up",
    "destroy": "doppler run --no-cache --config prd -- pnpm alchemy:down",
    "typecheck": "tsc --noEmit",
    "test": "pnpm typecheck && pnpm test:unit",
    "test:unit": "pnpm exec vitest run --config ./vitest.unit.config.ts",
    "test:e2e": "doppler run --no-cache -- pnpm exec vitest run --config ./e2e/vitest.config.ts",
    "test:e2e:record": "doppler run --no-cache -- env AGENTS_E2E_RECORD_HAR=1 pnpm exec vitest run --config ./e2e/vitest.config.ts --tags-filter mocked-internet",
    "test:e2e:runtime-smoke": "doppler run --no-cache -- sh -c 'if [ -z \"$AGENTS_BASE_URL\" ]; then echo \"AGENTS_BASE_URL is required\"; exit 1; fi; export AGENTS_E2E_RUNTIME_SMOKE=1; pnpm exec vitest run --config ./e2e/vitest.config.ts --tags-filter deployed-live-worker'"
  },
  "iterateAppCli": {
    "remote": {
      "defaultBaseUrl": "https://agents.iterate.com"
    }
  },
  "dependencies": {
    "@cloudflare/codemode": "catalog:cloudflare",
    "@iterate-com/agents-contract": "workspace:*",
    "@iterate-com/events-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@orpc/client": "1.13.14",
    "@orpc/contract": "1.13.14",
    "@orpc/openapi": "1.13.14",
    "@orpc/openapi-client": "1.13.14",
    "@orpc/server": "1.13.14",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "1.168.3",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "1.167.5",
    "agents": "^0.11.0",
    "ai": "^6.0.159",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "schematch": "0.2.1",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:cloudflare",
    "@cloudflare/vitest-pool-workers": "catalog:cloudflare",
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@iterate-com/mock-http-proxy": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.92.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "4.1.0-beta.6",
    "wrangler": "catalog:cloudflare"
  }
}
