{
  "name": "@iterate-com/os2",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "~/*": "./src/*"
  },
  "scripts": {
    "alchemy:up": "tsx ./alchemy.run.ts",
    "alchemy:down": "tsx ./alchemy.run.ts --destroy",
    "cli": "doppler run --project os2 -- iterate-app-cli",
    "dev": "pnpm cf:dev",
    "build": "doppler run -- pnpm exec vite build",
    "rpc": "pnpm cli rpc",
    "cf:dev": "doppler run --project os2 -- tsx ./alchemy.run.ts",
    "cf:deploy": "doppler run --project os2 --config prd -- pnpm alchemy:up",
    "cf:destroy": "doppler run --project os2 --config prd -- pnpm alchemy:down",
    "sqlfu:check": "sqlfu check all",
    "sqlfu:generate": "sqlfu generate && pnpm exec oxfmt src/db/queries/.generated src/db/migrations/.generated",
    "sqlfu:migrate": "sqlfu migrate",
    "sqlfu:ui": "sqlfu",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node -e \"if (!process.env.OS2_BASE_URL) { console.error('OS2_BASE_URL is required for OS e2e tests'); process.exit(1); }\" && vitest run --config ./e2e/vitest.config.ts",
    "test:smoke": "RUNTIME_SMOKE_FULL=1 vitest run",
    "test:watch": "vitest"
  },
  "iterateAppCli": {
    "remote": {
      "defaultBaseUrl": "https://os2.iterate.com"
    }
  },
  "dependencies": {
    "@iterate-com/os2-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@orpc/client": "1.13.14",
    "@orpc/contract": "1.13.14",
    "@orpc/openapi": "1.13.14",
    "@orpc/openapi-client": "1.13.14",
    "@orpc/server": "1.13.14",
    "@orpc/tanstack-query": "1.13.14",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-form-devtools": "^0.2.19",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "1.168.3",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "1.167.5",
    "crossws": "^0.4.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sqlfu": "0.0.3-8",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:cloudflare",
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.83.3",
    "esbuild": "^0.27.4",
    "iterate": "workspace:*",
    "miniflare": "catalog:cloudflare",
    "tinyexec": "^1.0.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "4.0.15",
    "wrangler": "catalog:cloudflare"
  }
}
