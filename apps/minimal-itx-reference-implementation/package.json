{
  "name": "minimal-itx-reference-implementation",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A single, minimal, coherent reference implementation of itx (Iterate's Cap'n Web capability layer): a capability context is the fold of a durable event log, served over a naked Cap'n Web stub.",
  "scripts": {
    "dev": "wrangler dev",
    "test": "pnpm typecheck",
    "e2e": "vitest run",
    "typecheck": "pnpm types:wrangler && tsc --noEmit -p tsconfig.json",
    "types:wrangler": "wrangler types worker-configuration.d.ts",
    "types:wrangler:check": "wrangler types worker-configuration.d.ts --check"
  },
  "dependencies": {
    "@iterate-com/os": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "capnweb": "^0.8.0",
    "ws": "^8.18.0",
    "zod": "~4.3.6"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "^4.1.7",
    "playwright": "1.57.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7",
    "wrangler": "4.101.0"
  }
}
