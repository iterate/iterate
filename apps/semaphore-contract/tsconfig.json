{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2024",
    "module": "ESNext",
    "lib": ["ES2024", "DOM"],
    "paths": {
      "@iterate-com/shared/*": ["../../packages/shared/src/*"]
    },
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"]
}
