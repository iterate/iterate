{
  "name": "@iterate-com/example",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "doppler run -- pnpm cli dev",
    "dev:embedded": "doppler run -- sh -c 'vite --config vite.embedded.config.ts --host 0.0.0.0 --port ${PORT:-17401}'",
    "build": "doppler run -- sh -c 'NODE_ENV=production vite build && pnpm typecheck'",
    "cloudflare:build": "doppler run -- vite build --config vite.cloudflare.config.ts && pnpm typecheck",
    "cloudflare:deploy": "pnpm cloudflare:build && doppler run -- wrangler deploy",
    "cloudflare:dev": "doppler run -- vite dev --config vite.cloudflare.config.ts",
    "cloudflare:preview": "pnpm cloudflare:build && doppler run -- vite preview --config vite.cloudflare.config.ts",
    "preview": "doppler run -- pnpm cli preview",
    "worker:dev": "doppler run -- sh -c 'NODE_ENV=production vite build && pnpm typecheck && ALCHEMY_STAGE=dev ALCHEMY_LOCAL=true ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./src/cloudflare/alchemy.run.ts cli --dev'",
    "worker:deploy": "doppler run -- sh -c 'NODE_ENV=production vite build && pnpm typecheck && ALCHEMY_STAGE=dev ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./src/cloudflare/alchemy.run.ts cli deploy'",
    "worker:destroy": "doppler run -- sh -c 'ALCHEMY_STAGE=dev ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./src/cloudflare/alchemy.run.ts cli --destroy'",
    "test:embedded-dev": "tsx ./scripts/test-embedded-dev.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cli": "tsx ./scripts/cli.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@hono/node-ws": "^1.3.0",
    "@iterate-com/example-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@lydell/node-pty": "1.2.0-beta.3",
    "@orpc/client": "*",
    "@orpc/contract": "*",
    "@orpc/openapi": "*",
    "@orpc/openapi-client": "^1.13.7",
    "@orpc/server": "*",
    "@orpc/tanstack-query": "*",
    "@orpc/zod": "*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "@xterm/addon-serialize": "0.15.0-beta.103",
    "@xterm/headless": "6.1.0-beta.103",
    "alchemy": "^0.83.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.1",
    "get-port-please": "^3.2.0",
    "trpc-cli": "0.12.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18",
    "wrangler": "^4.75.0"
  }
}
