{
  "name": "@iterate-com/example",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "doppler run -- pnpm cli dev",
    "build": "doppler run -- sh -c 'NODE_ENV=production vite build && pnpm typecheck'",
    "preview": "doppler run -- pnpm cli preview",
    "worker:dev": "doppler run -- sh -c 'NODE_ENV=production vite build && pnpm typecheck && ALCHEMY_STAGE=dev ALCHEMY_LOCAL=true ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./src/cloudflare/alchemy.run.ts cli --dev'",
    "worker:deploy": "doppler run -- sh -c 'NODE_ENV=production vite build && pnpm typecheck && ALCHEMY_STAGE=dev ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./src/cloudflare/alchemy.run.ts cli deploy'",
    "worker:destroy": "doppler run -- sh -c 'ALCHEMY_STAGE=dev ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./src/cloudflare/alchemy.run.ts cli --destroy'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cli": "tsx ./scripts/cli.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@iterate-com/example-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@orpc/client": "*",
    "@orpc/contract": "*",
    "@orpc/openapi": "*",
    "@orpc/openapi-client": "^1.13.7",
    "@orpc/server": "*",
    "@orpc/tanstack-query": "*",
    "@orpc/zod": "*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "alchemy": "^0.83.3",
    "canvas-confetti": "^1.9.4",
    "crossws": "^0.4.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.1",
    "get-port-please": "^3.2.0",
    "trpc-cli": "0.12.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18",
    "wrangler": "^4.73.0"
  }
}
