{
  "name": "@iterate-com/example",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "~/*": "./src/*"
  },
  "scripts": {
    "alchemy:up": "tsx ./alchemy.run.ts",
    "alchemy:down": "tsx ./alchemy.run.ts --destroy",
    "cli": "doppler run --project example -- iterate-app-cli",
    "dev": "doppler run -- vite dev",
    "build": "doppler run -- vite build",
    "preview": "doppler run -- vite preview",
    "rpc": "pnpm cli rpc",
    "start": "pnpm cli start",
    "cf:dev": "doppler run --project example -- tsx ./alchemy.run.ts",
    "cf:deploy": "doppler run --project example --config prd -- pnpm alchemy:up",
    "cf:destroy": "doppler run --project example --config prd -- pnpm alchemy:down",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node -e \"if (!process.env.EXAMPLE_BASE_URL) { console.error('EXAMPLE_BASE_URL is required for example e2e tests'); process.exit(1); }\" && vitest run --config ./e2e/vitest.config.ts",
    "test:smoke": "RUNTIME_SMOKE_FULL=1 vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@iterate-com/example-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@lydell/node-pty": "1.2.0-beta.3",
    "@orpc/client": "1.13.13",
    "@orpc/contract": "1.13.13",
    "@orpc/openapi": "1.13.13",
    "@orpc/openapi-client": "1.13.13",
    "@orpc/server": "1.13.13",
    "@orpc/tanstack-query": "1.13.13",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-form-devtools": "^0.2.19",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "1.168.3",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "1.167.5",
    "@xterm/addon-serialize": "0.15.0-beta.103",
    "@xterm/headless": "6.1.0-beta.103",
    "crossws": "^0.4.4",
    "drizzle-orm": "^0.45.1",
    "nitro": "3.0.260311-beta",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@lydell/node-pty-darwin-arm64": "1.2.0-beta.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "alchemy": "^0.83.3",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.1",
    "esbuild": "^0.27.4",
    "get-port": "^7.1.0",
    "iterate": "workspace:*",
    "nodemon": "^3.1.14",
    "tinyexec": "^1.0.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "4.0.15",
    "wrangler": "^4.75.0"
  }
}
