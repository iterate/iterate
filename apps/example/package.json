{
  "name": "@iterate-com/example",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "doppler run -- vite",
    "build": "doppler run -- vite build",
    "preview": "doppler run -- vite build && doppler run -- vite preview",
    "start": "doppler run -- vite preview",
    "cf:dev": "doppler run -- vite dev --config vite.cloudflare.config.ts",
    "cf:build": "doppler run -- vite build --config vite.cloudflare.config.ts",
    "cf:deploy": "pnpm cf:build && doppler run -- wrangler deploy",
    "test:embedded-dev": "tsx ./scripts/test-embedded-dev.ts dev",
    "test:start": "tsx ./scripts/test-embedded-dev.ts start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@hono/node-ws": "^1.3.0",
    "@iterate-com/example-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@lydell/node-pty": "1.2.0-beta.3",
    "@orpc/client": "*",
    "@orpc/contract": "*",
    "@orpc/openapi": "*",
    "@orpc/openapi-client": "^1.13.7",
    "@orpc/server": "*",
    "@orpc/tanstack-query": "*",
    "@orpc/zod": "*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "@xterm/addon-serialize": "0.15.0-beta.103",
    "@xterm/headless": "6.1.0-beta.103",
    "alchemy": "^0.83.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.75.0"
  }
}
