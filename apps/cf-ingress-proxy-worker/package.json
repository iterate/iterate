{
  "name": "@iterate-com/cf-ingress-proxy-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "doppler run --config dev -- sh -c 'WORKER_NAME=ingress-proxy-dev tsx ./alchemy.run.ts cli --dev --stage dev'",
    "deploy:prd": "doppler run --config prd -- sh -c 'WORKER_NAME=ingress-proxy tsx ./alchemy.run.ts cli deploy --stage prd'",
    "deploy": "pnpm run deploy:prd",
    "test": "vitest run",
    "test:e2e-live": "vitest run --config ./vitest.live.config.ts",
    "typecheck": "tsc --noEmit",
    "db:rebuild": "rm -f .local.db && sqlite3 .local.db < schema.sql",
    "db:types": "pnpm run db:rebuild && tsx ./scripts/generate-queries.ts --force",
    "db:types:stale": "tsx ./scripts/generate-queries.ts --if-stale",
    "db:watch": "pnpm run db:rebuild && tsx ./scripts/generate-queries.ts --watch"
  },
  "dependencies": {
    "@orpc/server": "^1.13.4",
    "alchemy": "^0.83.0",
    "hono": "^4.11.3",
    "typeid-js": "^1.2.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.17",
    "@cloudflare/workers-types": "^4.20260207.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "3.2.4",
    "wrangler": "^4.64.0",
    "typesql-cli": "^0.22.0"
  }
}
