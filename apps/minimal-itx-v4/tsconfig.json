{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "ESNext.Disposable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "types": ["@cloudflare/workers-types"],
    "verbatimModuleSyntax": false
  },
  // Worker program only. Node-side client/test/script files are checked by
  // tsconfig.node.json.
  "include": ["src/worker.ts", "worker-configuration.d.ts"],
  "exclude": ["src/client.ts", "src/examples/**/*.ts", "src/**/*.test.ts"]
}
