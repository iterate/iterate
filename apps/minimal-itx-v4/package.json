{
  "name": "minimal-itx-v4",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A smaller ITX reference: stateless Cap'n Web capability tree plus a tiny stream-backed dynamic capability processor.",
  "scripts": {
    "dev": "wrangler dev",
    "repl": "tsx scripts/repl.ts",
    "test": "pnpm typecheck",
    "e2e": "vitest run",
    "typecheck": "pnpm types:wrangler && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.wrangler-proof.json",
    "create:deployed-project": "tsx scripts/create-deployed-project.ts",
    "verify:deployed": "tsx scripts/verify-deployed.ts",
    "verify:miniflare": "tsx scripts/verify-miniflare.ts",
    "types:wrangler": "wrangler types worker-configuration.d.ts --include-runtime false",
    "types:wrangler:check": "wrangler types worker-configuration.d.ts --include-runtime false --check",
    "types:wrangler:proof": "tsc --noEmit -p tsconfig.wrangler-proof.json",
    "types:wrangler:proof:check": "pnpm types:wrangler:proof"
  },
  "dependencies": {
    "@cloudflare/shell": "^0.3.4",
    "capnweb": "^0.8.0",
    "ws": "^8.18.0",
    "zod": "~4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260621.1",
    "@slack/web-api": "^7.14.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7",
    "wrangler": "4.102.0"
  }
}
