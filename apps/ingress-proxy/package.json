{
  "name": "@iterate-com/ingress-proxy",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "secret:sync:ingress-proxy-api-token": "wrangler secret put INGRESS_PROXY_API_TOKEN",
    "types:env": "wrangler types worker-configuration.d.ts --env production --strict-vars=false",
    "test": "vitest run",
    "test:e2e-live": "vitest run --config ./vitest.live.config.ts",
    "typecheck": "tsc --noEmit",
    "db:rebuild": "rm -f .local.db && sqlite3 .local.db '' && find sql/migrations -name '*.sql' -print | sort | while read -r file; do sqlite3 .local.db < \"$file\"; done && sqlite3 .local.db '.schema --indent' > sql/schema.sql",
    "db:types": "tsx ./scripts/generate-queries.ts --force",
    "db:types:stale": "tsx ./scripts/generate-queries.ts --if-stale",
    "db:watch": "tsx ./scripts/generate-queries.ts --watch"
  },
  "dependencies": {
    "@iterate-com/ingress-proxy-contract": "workspace:*",
    "@iterate-com/shared": "workspace:*",
    "@orpc/openapi": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "@orpc/zod": "^1.13.6",
    "hono": "^4.12.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260207.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typesql-cli": "github:iterate/typesql#5687eb2",
    "typescript": "^5.9.3",
    "vitest": "3.2.4",
    "wrangler": "^4.64.0"
  }
}
