{
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": [
    "alchemy.run.ts",
    "test-quarantine/**",
    "tmp/**",
    "iterate-config-repo/**",
    "**/*.workerd.test.ts",
    "**/*.workers.test.ts",
    "src/domains/streams/engine/vitest.workers.config.ts",
    "src/durable-objects/*.test.ts",
    "../../packages/shared/src/alchemy/**"
  ],
  "compilerOptions": {
    "target": "ES2024",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "~/*": ["./src/*"],
      "@iterate-com/ui/*": ["../../packages/ui/src/*"],
      "@iterate-com/shared/*": ["../../packages/shared/src/*"]
    },
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node", "@cloudflare/workers-types"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true
  }
}
