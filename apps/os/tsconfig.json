{
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": [
    "alchemy.run.ts",
    "tmp/**",
    "iterate-config-repo/**",
    "**/*.workerd.test.ts",
    "src/durable-objects/*.test.ts",
    "../../packages/shared/src/alchemy/**"
  ],
  "compilerOptions": {
    "target": "ES2024",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "captun/client": ["./node_modules/captun/dist/client.js"],
      "captun/server": ["./node_modules/captun/dist/server.js"],
      "~/*": ["./src/*"],
      "@iterate-com/ui/*": ["../../packages/ui/src/*"],
      "@iterate-com/shared/*": ["../../packages/shared/src/*"],
      "@iterate-com/shared/posthog/vite-plugin": [
        "../../packages/shared/src/posthog/sourcemaps-vite-plugin.ts"
      ]
    },
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node", "@cloudflare/workers-types"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true
  }
}
