{
  "name": "os-project-ingress-vitest",
  "main": "project-ingress-test-entry.ts",
  "compatibility_date": "2026-04-27",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "APP_CONFIG": "{\"adminApiSecret\":\"project-ingress-admin-secret\",\"openAiApiKey\":\"openai-test-key\",\"projectHostnameBases\":[\"iterate.localhost\"],\"typeIdPrefix\":\"os\"}",
  },
  "worker_loaders": [
    {
      "binding": "LOADER",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "PROJECT",
        "class_name": "ProjectDurableObject",
      },
      {
        "name": "AGENT",
        "class_name": "AgentDurableObject",
      },
      {
        "name": "PROJECT_MCP_SERVER_CONNECTION",
        "class_name": "ProjectMcpServerConnection",
      },
      {
        "name": "STREAM",
        "class_name": "StreamDurableObject",
      },
      {
        "name": "REPO",
        "class_name": "RepoDurableObject",
      },
      {
        "name": "WORKSPACE",
        "class_name": "WorkspaceDurableObject",
      },
    ],
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "os-project-ingress-vitest",
      "database_name": "os-project-ingress-vitest",
      "preview_database_id": "os-project-ingress-vitest",
    },
    {
      "binding": "DO_CATALOG",
      "database_id": "os-project-ingress-catalog-vitest",
      "database_name": "os-project-ingress-catalog-vitest",
      "preview_database_id": "os-project-ingress-catalog-vitest",
    },
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ProjectDurableObject", "ProjectMcpServerConnection"],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["StreamDurableObject"],
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["AgentDurableObject"],
    },
    {
      "tag": "v4",
      "new_sqlite_classes": ["RepoDurableObject"],
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["WorkspaceDurableObject"],
    },
  ],
}
