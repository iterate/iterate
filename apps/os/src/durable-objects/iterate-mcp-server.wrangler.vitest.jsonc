{
  "name": "os-project-mcp-server-connection-vitest",
  "main": "iterate-mcp-server-test-entry.ts",
  "compatibility_date": "2026-04-27",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    // The uniform isolate env wires STREAMS into every loaded isolate
    // (itx/isolate.ts); StreamsBackend parses APP_CONFIG at instantiation.
    "APP_CONFIG": "{\"adminApiSecret\":\"mcp-test-admin-secret\",\"openAiApiKey\":\"openai-test-key\",\"projectHostnameBases\":[\"iterate.localhost\"],\"typeIdPrefix\":\"os\"}",
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "PROJECT_MCP_SERVER_CONNECTION",
        "class_name": "ProjectMcpServerConnection",
      },
      {
        "name": "REPO",
        "class_name": "RepoDurableObject",
      },
      {
        "name": "WORKSPACE",
        "class_name": "WorkspaceDurableObject",
      },
      {
        "name": "AGENT",
        "class_name": "AgentDurableObject",
      },
      {
        "name": "STREAM",
        "class_name": "StreamDurableObject",
      },
      {
        "name": "ITX_CONTEXT",
        "class_name": "ItxDurableObject",
      },
    ],
  },
  "d1_databases": [
    // Same database under both names — DB and DO_CATALOG alias one D1 in
    // real deployments, and the itx context catalog reads env.DB.
    {
      "binding": "DB",
      "database_id": "os-project-mcp-server-connection-vitest",
      "database_name": "os-project-mcp-server-connection-vitest",
      "preview_database_id": "os-project-mcp-server-connection-vitest",
    },
    {
      "binding": "DO_CATALOG",
      "database_id": "os-project-mcp-server-connection-vitest",
      "database_name": "os-project-mcp-server-connection-vitest",
      "preview_database_id": "os-project-mcp-server-connection-vitest",
    },
  ],
  "worker_loaders": [
    {
      "binding": "LOADER",
    },
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ProjectMcpServerConnection"],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["StreamDurableObject"],
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["RepoDurableObject", "WorkspaceDurableObject", "AgentDurableObject"],
    },
    {
      "tag": "v4",
      "new_sqlite_classes": ["ItxDurableObject"],
    },
  ],
}
