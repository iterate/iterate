{
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "compilerOptions": {
    "target": "ES2024",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "~/*": ["./src/*"],
      "@iterate-com/ui/*": ["../../packages/ui/src/*"]
    },
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true
  }
}
