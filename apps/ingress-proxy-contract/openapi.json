{
  "info": {
    "title": "Ingress Proxy API",
    "version": "0.0.1"
  },
  "servers": [
    {
      "url": "/api"
    }
  ],
  "openapi": "3.1.1",
  "paths": {
    "/__internal/health": {
      "get": {
        "operationId": "__internal.health",
        "tags": ["(internal)"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "const": true
                    },
                    "app": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  },
                  "required": ["ok", "app", "version"]
                }
              }
            }
          }
        }
      }
    },
    "/__internal/public-config": {
      "get": {
        "operationId": "__internal.publicConfig",
        "tags": ["(internal)"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {}
                }
              }
            }
          }
        }
      }
    },
    "/__internal/debug": {
      "get": {
        "operationId": "common.debug",
        "tags": ["(internal)"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {}
                }
              }
            }
          }
        }
      }
    },
    "/__internal/refresh-registry": {
      "post": {
        "operationId": "__internal.refreshRegistry",
        "tags": ["(internal)"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "registryBaseUrl": {
                    "type": "string",
                    "format": "uri",
                    "default": "http://iterate.localhost"
                  },
                  "baseUrl": {
                    "type": "string",
                    "format": "uri"
                  }
                },
                "default": {
                  "registryBaseUrl": "http://iterate.localhost"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "const": true
                    }
                  },
                  "required": ["ok"]
                }
              }
            }
          }
        }
      }
    },
    "/routes/{rootHost}": {
      "put": {
        "operationId": "routes.upsert",
        "tags": ["Routes"],
        "parameters": [
          {
            "name": "rootHost",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "targetUrl": {
                    "type": "string"
                  },
                  "metadata": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {},
                    "default": {}
                  }
                },
                "required": ["targetUrl"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "rootHost": {
                      "type": "string",
                      "minLength": 1
                    },
                    "targetUrl": {
                      "type": "string",
                      "minLength": 1
                    },
                    "metadata": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {}
                    },
                    "createdAt": {
                      "type": "string"
                    },
                    "updatedAt": {
                      "type": "string"
                    }
                  },
                  "required": ["id", "rootHost", "targetUrl", "metadata", "createdAt", "updatedAt"]
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "routes.get",
        "tags": ["Routes"],
        "parameters": [
          {
            "name": "rootHost",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "rootHost": {
                      "type": "string",
                      "minLength": 1
                    },
                    "targetUrl": {
                      "type": "string",
                      "minLength": 1
                    },
                    "metadata": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {}
                    },
                    "createdAt": {
                      "type": "string"
                    },
                    "updatedAt": {
                      "type": "string"
                    }
                  },
                  "required": ["id", "rootHost", "targetUrl", "metadata", "createdAt", "updatedAt"]
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "routes.remove",
        "tags": ["Routes"],
        "parameters": [
          {
            "name": "rootHost",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {},
                "required": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted": {
                      "type": "boolean"
                    }
                  },
                  "required": ["deleted"]
                }
              }
            }
          }
        }
      }
    },
    "/routes": {
      "get": {
        "operationId": "routes.list",
        "tags": ["Routes"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 100,
              "exclusiveMinimum": 0,
              "default": 100
            },
            "allowEmptyValue": true,
            "allowReserved": true
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991,
              "default": 0
            },
            "allowEmptyValue": true,
            "allowReserved": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "routes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "minLength": 1
                          },
                          "rootHost": {
                            "type": "string",
                            "minLength": 1
                          },
                          "targetUrl": {
                            "type": "string",
                            "minLength": 1
                          },
                          "metadata": {
                            "type": "object",
                            "propertyNames": {
                              "type": "string"
                            },
                            "additionalProperties": {}
                          },
                          "createdAt": {
                            "type": "string"
                          },
                          "updatedAt": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "rootHost",
                          "targetUrl",
                          "metadata",
                          "createdAt",
                          "updatedAt"
                        ]
                      }
                    },
                    "total": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": ["routes", "total"]
                }
              }
            }
          }
        }
      }
    }
  }
}
