{
  "name": "@iterate-com/ws-test-2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm cli dev",
    "build": "NODE_ENV=production vite build && pnpm typecheck",
    "preview": "pnpm cli preview",
    "worker:dev": "ALCHEMY_STAGE=dev ALCHEMY_LOCAL=true ALCHEMY_CI_STATE_STORE_CHECK=false pnpm build && ALCHEMY_STAGE=dev ALCHEMY_LOCAL=true ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./alchemy.run.ts cli --dev",
    "worker:deploy": "ALCHEMY_STAGE=dev ALCHEMY_CI_STATE_STORE_CHECK=false pnpm build && ALCHEMY_STAGE=dev ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./alchemy.run.ts cli deploy",
    "worker:destroy": "ALCHEMY_STAGE=dev ALCHEMY_CI_STATE_STORE_CHECK=false tsx ./alchemy.run.ts cli --destroy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment node e2e.test.ts",
    "test:e2e-live": "vitest run --environment node worker-live.test.ts",
    "cli": "tsx ./src/cli.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@iterate-com/shared": "workspace:*",
    "@iterate-com/ui": "workspace:*",
    "@iterate-com/ws-test-2-contract": "workspace:*",
    "@orpc/client": "*",
    "@orpc/contract": "*",
    "@orpc/openapi": "*",
    "@orpc/openapi-client": "^1.13.7",
    "@orpc/server": "*",
    "@orpc/tanstack-query": "*",
    "@orpc/zod": "*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@xterm/addon-serialize": "0.15.0-beta.103",
    "@xterm/headless": "6.1.0-beta.103",
    "alchemy": "^0.83.3",
    "canvas-confetti": "^1.9.4",
    "crossws": "^0.4.4",
    "hono": "^4.12.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "schematch": "0.2.1",
    "tailwindcss": "^4.2.1",
    "tinyexec": "^1.0.2",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "get-port-please": "^3.2.0",
    "trpc-cli": "0.12.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18",
    "wrangler": "^4.73.0"
  },
  "optionalDependencies": {
    "@lydell/node-pty": "^1.1.0"
  }
}
